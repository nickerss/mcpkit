---
import '../styles/global.css';
import { getLocaleFromUrl } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const { title, description = '独立开发者的 AI Agent 工具箱' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={locale} data-lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ locale }}>
      (function() {
        var urlLang = new URLSearchParams(window.location.search).get('lang');
        var storedLang = localStorage.getItem('mcpkit-lang');
        var lang = urlLang || storedLang || locale || 'en';
        if (lang !== 'en' && lang !== 'zh') lang = 'en';

        var texts = {
          en: {
            nav: ['Kits', 'All Tools', 'Search'],
            navHrefs: ['/?lang=zh', '/kits/ship-a-saas/?lang=zh', '/search/?lang=zh'],
            heroTitle: 'Your AI Agent',
            heroAccent: 'Toolkit',
            heroSubtitle: 'Kit-based tool combos · Verified · Rated',
            heroPlaceholder: 'Search tools...',
            sectionFeatured: 'Featured',
            sectionLatest: 'Latest Added',
            footerCopy: '© 2026 MCPKIT — AI Agent Tools for Independent Developers',
            footerLinks: ['Search', 'Submit Tool']
          },
          zh: {
            nav: ['Kits', '所有工具', '搜索'],
            navHrefs: ['/?lang=zh', '/kits/ship-a-saas/?lang=zh', '/search/?lang=zh'],
            heroTitle: '独立开发者的',
            heroAccent: 'AI Agent 工具箱',
            heroSubtitle: 'Kit 化工具套件 · 精选认证 · 四维评测',
            heroPlaceholder: '搜索工具...',
            sectionFeatured: '编辑精选',
            sectionLatest: '最新收录',
            footerCopy: '© 2026 MCPKIT — 独立开发者的 AI Agent 工具箱',
            footerLinks: ['搜索', '提交工具']
          }
        };

        var t = texts[lang] || texts.en;

        // Nav links
        var navLinks = document.querySelectorAll('.nav-link');
        navLinks.forEach(function(el, i) {
          if (t.nav[i]) {
            el.textContent = t.nav[i];
            el.setAttribute('href', t.navHrefs[i]);
          }
        });

        // Logo href
        var logoLink = document.querySelector('.logo');
        if (logoLink) logoLink.setAttribute('href', '/?lang=' + lang);

        // Hero title (h1) — preserve gradient span, set only text before <br>
        var heroTitle = document.querySelector('.hero-title');
        if (heroTitle) {
          var hasBr = heroTitle.innerHTML.indexOf('<br') !== -1;
          if (hasBr) {
            var accent = heroTitle.querySelector('.gradient-text');
            if (accent) accent.textContent = t.heroAccent;
            var parts = heroTitle.innerHTML.split('<br');
            heroTitle.innerHTML = t.heroTitle + '<br' + parts[1];
          } else {
            heroTitle.textContent = t.heroTitle + ' ' + t.heroAccent;
          }
        }

        // Hero subtitle
        var heroSubtitle = document.querySelector('.hero-subtitle');
        if (heroSubtitle) heroSubtitle.textContent = t.heroSubtitle;

        // Hero desc (some pages use this)
        var heroDesc = document.querySelector('.hero-desc');
        if (heroDesc) heroDesc.textContent = t.heroSubtitle;

        // Search input placeholder
        var searchInput = document.querySelector('.search-input');
        if (searchInput) searchInput.setAttribute('placeholder', t.heroPlaceholder);

        // Section titles
        var sectionTitles = document.querySelectorAll('.section-title');
        if (sectionTitles[0]) sectionTitles[0].textContent = t.sectionFeatured;
        if (sectionTitles[1]) sectionTitles[1].textContent = t.sectionLatest;

        // Footer copyright
        var copyright = document.querySelector('.copyright');
        if (copyright) copyright.textContent = t.footerCopy;
        var footerLinks = document.querySelectorAll('.footer .link');
        if (footerLinks[0]) footerLinks[0].textContent = t.footerLinks[0];
        if (footerLinks[1]) footerLinks[1].textContent = t.footerLinks[1];

        // Update HTML lang
        document.documentElement.lang = lang;

        // Update all href with ?lang= for zh
        if (lang === 'zh') {
          var allLinks = document.querySelectorAll('a[href]');
          allLinks.forEach(function(link) {
            var href = link.getAttribute('href');
            if (href && !href.startsWith('http') && !href.includes('?')) {
              link.setAttribute('href', href + '?lang=zh');
            }
          });
        }
      })();
    </script>
  </body>
</html>