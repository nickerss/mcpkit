---
import '../styles/global.css';
import { getLocaleFromUrl } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const { title, description = '独立开发者的 AI Agent 工具箱' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={locale} data-lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('mcpkit-theme');
        var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', saved || preferred);
      })();
    </script>
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ locale }}>
      (function() {
        var lang = locale || 'en';
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('lang') === 'zh') lang = 'zh';
        if (urlParams.get('lang') === 'en') lang = 'en';
        var stored = localStorage.getItem('mcpkit-lang');
        if (stored === 'zh' || stored === 'en') lang = stored;

        var texts = {
          en: {
            'nav.explore': 'Explore Tools',
            'nav.kits': 'Kit Zone',
            'nav.developers': 'Developers',
            'nav.pricing': 'Pricing',
            'nav.login': 'Login',
            'nav.logout': 'Logout',
            'nav.submit': 'Submit Tool',
            'hero.title': 'Trusted Lego-style Toolkit',
            'hero.accent': 'for Your AI Agent',
            'hero.subtitle': 'Discover · Verify · Combine — all in one place.',
            'hero.badge': 'AI Agent Toolkit Discovery & Verification Platform',
            'hero.search': 'Search tools...',
            'home.featured': 'Featured',
            'home.latest': 'Latest Added',
            'page.title': 'MCPKIT — AI Agent Tools for Independent Developers',
            'lang.en': 'EN',
            'lang.zh': '中文'
          },
          zh: {
            'nav.explore': '探索工具',
            'nav.kits': 'Kit专区',
            'nav.developers': '开发者',
            'nav.pricing': '定价',
            'nav.login': '登录',
            'nav.logout': '退出',
            'nav.submit': '提交工具',
            'hero.title': '为你的 AI Agent',
            'hero.accent': '装上可信的乐高式工具包',
            'hero.subtitle': '发现 · 认证 · 组合，一站搞定。',
            'hero.badge': 'AI Agent 工具包发现与认证平台',
            'hero.search': '搜索工具...',
            'home.featured': '编辑精选',
            'home.latest': '最新收录',
            'page.title': 'MCPKIT — AI Agent 开发者工具目录',
            'lang.en': 'EN',
            'lang.zh': '中文'
          }
        };

        var t = texts[lang] || texts.en;

        function applyI18n(root) {
          root.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            if (t[key]) {
              if (el.tagName === 'INPUT' && el.getAttribute('placeholder') !== null) {
                el.setAttribute('placeholder', t[key]);
              } else {
                el.textContent = t[key];
              }
            }
          });
        }

        // Apply to full document
        applyI18n(document);

        // Apply to dynamically added content
        new MutationObserver(function(mutations) {
          mutations.forEach(function(m) {
            if (m.addedNodes.length) {
              m.addedNodes.forEach(function(node) {
                if (node.nodeType === 1) {
                  applyI18n(node);
                }
              });
            }
          });
        }).observe(document.body, { childList: true, subtree: true });

        // Update document title
        document.title = t['page.title'] || document.title;

        // Update lang attribute
        document.documentElement.lang = lang;
      })();
    </script>
  </body>
</html>