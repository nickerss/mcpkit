---
import '../styles/global.css';
import { getLocaleFromUrl } from '../i18n/index';

interface Props {
  title: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const { title, description = '独立开发者的 AI Agent 工具箱' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={locale} data-lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/src/styles/global.css" />
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('mcpkit-theme');
        var preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', saved || preferred);
      })();
    </script>
  </head>
  <body>
    <slot />
    <script is:inline define:vars={{ locale }}>
      (function() {
        var lang = locale || 'en';
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('lang') === 'zh') lang = 'zh';
        if (urlParams.get('lang') === 'en') lang = 'en';
        var stored = localStorage.getItem('mcpkit-lang');
        if (stored === 'zh' || stored === 'en') lang = stored;

        var texts = {
          en: {
            pageTitle: 'MCPKIT — AI Agent Tools for Independent Developers',
            nav: ['Explore Tools', 'Kit Zone', 'Developers', 'Pricing'],
            heroTitle: 'Trusted Lego-style Toolkit',
            heroAccent: 'for Your AI Agent',
            heroSubtitle: 'Discover · Verify · Combine — all in one place.',
            heroBadge: 'AI Agent Toolkit Discovery & Verification Platform',
            langLabel: 'EN'
          },
          zh: {
            pageTitle: 'MCPKIT — AI Agent 开发者工具目录',
            nav: ['探索工具', 'Kit专区', '开发者', '定价'],
            heroTitle: '为你的 AI Agent',
            heroAccent: '装上可信的乐高式工具包',
            heroSubtitle: '发现 · 认证 · 组合，一站搞定。',
            heroBadge: 'AI Agent 工具包发现与认证平台',
            langLabel: '中文'
          }
        };
        var t = texts[lang] || texts.en;

        // Page title
        document.title = t.pageTitle;

        // Nav links
        var navItems = document.querySelectorAll('[data-i18n-nav]');
        navItems.forEach(function(el, i) {
          if (t.nav[i]) el.textContent = t.nav[i];
        });

        // Hero title - has <br> and .gradient-text
        var heroTitle = document.querySelector('.hero-title');
        if (heroTitle) {
          var gradientText = heroTitle.querySelector('.gradient-text');
          if (gradientText) gradientText.textContent = t.heroAccent;
          var html = heroTitle.innerHTML;
          var brIdx = html.indexOf('<br');
          if (brIdx > -1) {
            heroTitle.innerHTML = t.heroTitle + html.substring(brIdx);
          }
        }

        // Hero subtitle
        var heroSub = document.querySelector('.hero-subtitle');
        if (heroSub) heroSub.textContent = t.heroSubtitle;

        // Hero badge
        var badge = document.querySelector('.hero-badge');
        if (badge) {
          var badgeSpan = badge.querySelector('span:last-child') || badge;
          badgeSpan.textContent = t.heroBadge;
        }

        // Language switcher label
        var langLabel = document.querySelector('.lang-switcher .lang-label');
        if (langLabel) langLabel.textContent = t.langLabel;

        // Update lang attribute
        document.documentElement.lang = lang;
      })();
    </script>
  </body>
</html>