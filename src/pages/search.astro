---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchBox from '../components/SearchBox.astro';
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';
---

<BaseLayout title={isZh ? '搜索工具 - mcpkit.run' : 'Search Tools - mcpkit.run'}>
  <Header />

  <main class="main">
    <div class="search-header">
      <div class="container">
        <h1 class="page-title">{isZh ? '搜索工具' : 'Search Tools'}</h1>
        <div class="search-wrap">
          <SearchBox placeholder={isZh ? '搜索工具...' : 'Search tools...'} />
        </div>
      </div>
    </div>

    <div class="container">
      <div id="search-results" class="results" data-pagefind-search>
        <p class="search-hint">{isZh ? '输入关键词搜索，支持中文和英文' : 'Enter keywords to search, supports Chinese and English'}</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main { min-height: calc(100vh - 60px); }
  .search-header { border-bottom: 1px solid var(--border-color); padding: 40px 0 32px; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .page-title { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 20px; text-align: center; }
  .search-wrap { max-width: 560px; margin: 0 auto; }
  .results { padding: 40px 0 80px; }
  .search-hint { text-align: center; color: var(--text-muted); font-size: 14px; }
</style>
