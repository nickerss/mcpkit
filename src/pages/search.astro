---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchBox from '../components/SearchBox.astro';
---

<BaseLayout title="搜索 - mcpkit.run" description="搜索 AI Agent 开发工具">
  <Header />

  <main class="main">
    <div class="search-header">
      <div class="container">
        <h1 class="page-title">搜索工具</h1>
        <div class="search-wrap">
          <SearchBox placeholder="搜索 MCP Servers、AI 工具..." />
        </div>
      </div>
    </div>

    <div class="container">
      <div id="search-results" class="results" data-pagefind-search>
        <p class="search-hint">输入关键词搜索工具，支持中文和英文</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Pagefind will initialize automatically after build
  // For now, show a helpful message in dev mode
  const results = document.getElementById('search-results');
  if (results) {
    results.addEventListener('pagefind:loaded', () => {
      console.log('Pagefind ready');
    });
  }
</script>

<style>
  .main {
    min-height: calc(100vh - 60px);
  }
  .search-header {
    border-bottom: 1px solid var(--border-color);
    padding: 40px 0 32px;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .page-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
    text-align: center;
  }
  .search-wrap {
    max-width: 560px;
    margin: 0 auto;
  }
  .results {
    padding: 40px 0 80px;
  }
  .search-hint {
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
  }
</style>
