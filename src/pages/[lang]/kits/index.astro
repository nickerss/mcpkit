---
const locale = 'zh';
const isZh = true;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';


// Fetch all kits
const kits = await getCollection('kits');

// Icon map for kit icons
const iconSvgs: Record<string, string> = {
  rocket: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
  bot: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
  search: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>',
  zap: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
  server: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" x2="6.01" y1="6" y2="6"/><line x1="6" x2="6.01" y1="18" y2="18"/></svg>',
};

// Rating colors
const ratingColors: Record<string, string> = {
  ship: '#f97316',
  coding: '#06b6d4',
  rag: '#8b5cf6',
  browser: '#eab308',
  devops: '#ef4444',
};

// Calculate kit aggregate rating
function getKitRating(kit: any): number {
  const starterTools = kit.levels?.starter?.tools || [];
  if (starterTools.length === 0) return 4.5;
  // Simple average based on tool count
  return Math.min(5, 4 + (starterTools.length * 0.1));
}

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' }, props: { locale: 'zh' } },
  ];
}
---

<BaseLayout locale={locale} title={isZh ? 'Kit 专区 - MCPKIT' : 'Kit Zone - MCPKIT'} description={isZh ? '为你的 AI Agent 选择最佳工具套装' : 'Choose the best tool kit for your AI Agent'}>
  <Header locale={locale} />
  
  <main class="kits-page">
    <!-- Page Header -->
    <section class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/">{isZh ? '首页' : 'Home'}</a>
          <span class="sep">›</span>
          <span>{isZh ? 'Kit 专区' : 'Kit Zone'}</span>
        </nav>
        
        <h1 class="page-title">
          <span class="en-hide">Kit Zone</span>
          <span class="zh-show">Kit 专区</span>
        </h1>
        <p class="page-subtitle">
          <span class="en-hide">Choose the best tool kit for your AI Agent</span>
          <span class="zh-show">为你的 AI Agent 选择最佳工具套装</span>
        </p>
        <p class="kit-count">
          <span class="count-number">{kits.length}</span>
          <span class="en-hide"> Kits</span>
          <span class="zh-show"> Kits</span>
        </p>
      </div>
    </section>

    <!-- Kit Grid -->
    <section class="kits-grid-section">
      <div class="container">
        <div class="kits-grid">
          {kits.map(kit => {
            const slug = kit.id.replace(/\.(md|mdx)$/, '');
            const starterTools = kit.data.levels?.starter?.tools || [];
            const toolCount = starterTools.length || 3;
            const rating = getKitRating(kit.data);
            const iconKey = kit.data.icon || 'server';
            const iconHtml = iconSvgs[iconKey] || iconSvgs.server;
            const color = kit.data.color || '#8b5cf6';
            const isCertified = kit.data.certificationStatus === 'certified';
            
            return (
              <a href={`/kits/${slug}/`} class="kit-card" style={`--kit-color: ${color}`}>
                <div class="kit-icon-wrap" style={`background: ${color}20`}>
                  <span class="kit-icon" set:html={iconHtml}></span>
                </div>
                
                <div class="kit-info">
                  <div class="kit-name-row">
                    <h3 class="kit-name">{isZh ? kit.data.title : (kit.data.titleEn || kit.data.title)}</h3>
                    <span class={`level-badge level-starter`}>Starter</span>
                  </div>
                  
                  <p class="kit-desc">
                    {isZh
                      ? (kit.data.tagline?.zh || kit.data.description)
                      : (kit.data.tagline?.en || kit.data.description)
                    }
                  </p>
                  
                  <div class="kit-tools">
                    {starterTools.slice(0, 4).join(' · ')}
                  </div>
                  
                  <div class="kit-meta">
                    <span class="rating" style={`color: ${color}`}>⭐ {rating.toFixed(1)}</span>
                    {isCertified && <span class="cert-badge">🏅 Certified</span>}
                    <span class="tool-count">{toolCount} tools</span>
                  </div>
                </div>
                
                <div class="kit-accent-bar"></div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  </main>
  
  <Footer locale={locale} />
</BaseLayout>

<style>
  .kits-page {
    min-height: 100vh;
  }
  
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  
  /* Page Header */
  .page-header {
    padding: 48px 0 32px;
    border-bottom: 1px solid var(--border);
  }
  
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  
  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  
  .breadcrumb a:hover {
    color: var(--text-secondary);
  }
  
  .sep {
    color: var(--text-muted);
  }
  
  .page-title {
    font-size: 36px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 8px;
  }
  
  .page-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
    margin: 0 0 16px;
  }
  
  .kit-count {
    font-size: 14px;
    color: var(--text-muted);
    margin: 0;
  }
  
  .count-number {
    font-weight: 700;
    color: var(--accent);
    font-size: 18px;
  }
  
  /* Kits Grid */
  .kits-grid-section {
    padding: 48px 0 80px;
  }
  
  .kits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  
  @media (max-width: 1023px) {
    .kits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 639px) {
    .kits-grid {
      grid-template-columns: 1fr;
    }
  }
  
  /* Kit Card */
  .kit-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 24px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 16px;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 250ms ease, box-shadow 250ms ease, border-color 250ms ease;
    cursor: pointer;
  }
  
  .kit-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
    border-color: var(--kit-color);
  }
  
  .kit-card:hover .kit-accent-bar {
    opacity: 1;
    transform: scaleY(1);
  }
  
  .kit-accent-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--kit-color);
    border-radius: 0 2px 2px 0;
    opacity: 0;
    transform: scaleY(0.8);
    transition: opacity 250ms ease, transform 250ms ease;
  }
  
  .kit-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--kit-color);
  }
  
  .kit-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .kit-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  
  .kit-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  
  .kit-name {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }
  
  .level-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 6px;
    text-transform: capitalize;
    border: 1px solid currentColor;
  }
  
  .level-starter { color: var(--free); border-color: var(--free); background: #22c55e10; }
  .level-pro { color: var(--paid); border-color: var(--paid); background: #f59e0b10; }
  .level-enterprise { color: #ef4444; border-color: #ef4444; background: #ef444410; }
  
  .kit-desc {
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .kit-tools {
    font-size: 12px;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  
  .kit-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    flex-wrap: wrap;
    margin-top: auto;
  }
  
  .rating { font-weight: 600; }
  
  .cert-badge {
    background: linear-gradient(135deg, #f59e0b, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-weight: 600;
  }
  
  .tool-count { color: var(--text-muted); }
</style>
