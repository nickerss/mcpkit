---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getLocaleFromUrl } from '../../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';

const sessionToken = Astro.cookies.get('session')?.value;
const isLoggedIn = !!sessionToken;

const dashboardTabs = [
  { id: 'claim', label: isZh ? '认领工具' : 'Claim Tool', href: '/dashboard/' },
  { id: 'submit-kit', label: isZh ? '提交 Kit' : 'Submit Kit', href: '/dashboard/submit-kit/' },
  { id: 'my-tools', label: isZh ? '我的工具' : 'My Tools', href: '/dashboard/my-tools/' },
];

const contentTabs = [
  { id: 'submitted', label: isZh ? '已提交' : 'Submitted' },
  { id: 'claimed', label: isZh ? '已认领' : 'Claimed' },
  { id: 'kits', label: isZh ? 'Kit 配方' : 'Kit Recipes' },
];
---

<BaseLayout title={isZh ? '我的工具 — MCPKIT' : 'My Tools — MCPKIT'}>
  <Header />

  <main class="main">
    <!-- Dashboard tab nav -->
    <div class="container">
      <nav class="tab-nav dashboard-tabs">
        {dashboardTabs.map(tab => (
          <a
            href={tab.href}
            class:list={['tab-btn', { active: tab.id === 'my-tools' }]}
          >
            {tab.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="page-header">
      <div class="container">
        <nav class="breadcrumb">
          <a href="/dashboard/">{isZh ? '仪表盘' : 'Dashboard'}</a>
          <span>/</span>
          <span>{isZh ? '我的工具' : 'My Tools'}</span>
        </nav>
        <h1 class="page-title">{isZh ? '我的工具' : 'My Tools'}</h1>
        <p class="page-desc">
          {isZh ? '查看和管理你提交或认领的所有工具和配方。' : 'View and manage all tools and recipes you have submitted or claimed.'}
        </p>
      </div>
    </div>

    <div class="container">
      {!isLoggedIn ? (
        <div class="login-required">
          <div class="login-card">
            <div class="login-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </div>
            <h2>{isZh ? '请先登录' : 'Please Sign In'}</h2>
            <p>{isZh ? '登录后才能查看和管理你的工具列表。' : 'Sign in to view and manage your tool listings.'}</p>
            <a href="/api/auth/github" class="btn-github">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              {isZh ? '使用 GitHub 登录' : 'Sign in with GitHub'}
            </a>
          </div>
        </div>
      ) : (
        <>
          <div class="tab-nav content-tabs">
            {contentTabs.map(tab => (
              <button class="tab-btn" data-tab={tab.id}>{tab.label}</button>
            ))}
          </div>

          <div id="tools-submitted" class="tab-panel active">
            <div class="tools-list" id="submitted-list"></div>
          </div>
          <div id="tools-claimed" class="tab-panel">
            <div class="tools-list" id="claimed-list"></div>
          </div>
          <div id="tools-kits" class="tab-panel">
            <div class="tools-list" id="kits-list"></div>
          </div>
        </>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<script define:vars={{ isLoggedIn: isLoggedIn, isZh }}>
  // Content tab switching
  document.querySelectorAll('.content-tabs .tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const tabId = btn.getAttribute('data-tab');
      document.querySelectorAll('.content-tabs .tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      const panel = document.getElementById(`tools-${tabId}`);
      if (panel) panel.classList.add('active');
    });
  });
  document.querySelector('.content-tabs .tab-btn')?.classList.add('active');
  document.querySelector('.tab-panel')?.classList.add('active');

  // Load user tools via API
  async function loadMyTools() {
    if (!isLoggedIn) return;
    try {
      const res = await fetch('/api/dashboard/my-tools', { credentials: 'include' });
      if (!res.ok) return;
      const data = await res.json();
      renderTools('submitted-list', data.submitted || [], 'submitted');
      renderTools('claimed-list', data.claimed || [], 'claimed');
      renderTools('kits-list', data.kits || [], 'kit');
    } catch (e) {
      console.error('Failed to load tools', e);
    }
  }

  function renderTools(listId, tools, type) {
    const list = document.getElementById(listId);
    if (!list) return;
    if (tools.length === 0) {
      list.innerHTML = `
        <div class="empty-state">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
          <p class="empty-title">${isZh ? '暂无工具' : 'No tools yet'}</p>
          <p class="empty-hint">${isZh ? '提交或认领第一个工具开始' : 'Submit or claim your first tool to get started'}</p>
          ${type !== 'kit' ? `<a href="/dashboard/" class="btn-primary">${isZh ? '认领工具' : 'Claim a Tool'}</a>` : `<a href="/dashboard/submit-kit/" class="btn-primary">${isZh ? '创建 Kit 配方' : 'Create Kit Recipe'}</a>`}
        </div>
      `;
      return;
    }
    list.innerHTML = '<div class="tools-grid">' + tools.map(tool => `
      <div class="tool-card">
        <div class="tool-card-header">
          <h3 class="tool-name">${escapeHtml(tool.name || tool.tool_name || '—')}</h3>
          <span class="tool-status status-${tool.status || 'pending'}">${tool.status || 'pending'}</span>
        </div>
        <p class="tool-meta">${isZh ? '日期' : 'Date'}: ${tool.created_at ? new Date(tool.created_at).toLocaleDateString() : '—'}</p>
        <div class="tool-actions">
          <a href="/tools/${tool.slug || tool.tool_slug || ''}" class="btn-view">${isZh ? '查看' : 'View'}</a>
        </div>
      </div>
    `).join('') + '</div>';
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  loadMyTools();
</script>

<style>
  .main { min-height: calc(100vh - 60px); padding-bottom: 80px; }
  .page-header { border-bottom: 1px solid var(--border-color); padding: 32px 0 28px; }
  .container { max-width: 960px; margin: 0 auto; padding: 0 24px; }
  .breadcrumb { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; font-size: 13px; color: var(--text-tertiary); }
  .breadcrumb a { color: var(--text-secondary); text-decoration: none; }
  .breadcrumb a:hover { color: var(--accent); }
  .page-title { font-size: 26px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
  .page-desc { color: var(--text-secondary); font-size: 15px; }

  .dashboard-tabs { border-bottom: none; padding-bottom: 0; }

  .tab-nav { display: flex; gap: 4px; padding: 24px 0 0; border-bottom: 1px solid var(--border-color); }
  .tab-btn {
    padding: 8px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition: all 150ms ease;
    text-decoration: none;
  }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

  .tab-panel { display: none; padding-top: 24px; }
  .tab-panel.active { display: block; }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 64px 24px;
    color: var(--text-tertiary);
    text-align: center;
  }
  .empty-title { font-size: 18px; font-weight: 600; color: var(--text-secondary); margin-top: 8px; }
  .empty-hint { font-size: 14px; color: var(--text-tertiary); max-width: 320px; }
  .btn-primary {
    margin-top: 8px;
    padding: 10px 24px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--accent-hover); }

  .login-required { display: flex; justify-content: center; padding: 32px 0; }
  .login-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 40px;
    text-align: center;
    max-width: 400px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .login-icon {
    width: 64px;
    height: 64px;
    background: var(--accent-muted);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
  }
  .login-card h2 { font-size: 20px; font-weight: 700; color: var(--text-primary); }
  .login-card p { font-size: 14px; color: var(--text-secondary); line-height: 1.5; }
  .btn-github {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 24px;
    background: #24292f;
    color: white;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 150ms ease;
  }
  .btn-github:hover { background: #3d4349; }

  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
  .tool-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tool-card-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .tool-name { font-size: 15px; font-weight: 600; color: var(--text-primary); }
  .tool-status {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 20px;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .status-pending { background: rgba(245,158,11,0.1); color: #f59e0b; }
  .status-approved, .status-active { background: rgba(34,197,94,0.1); color: #22c55e; }
  .status-rejected { background: rgba(239,68,68,0.1); color: #ef4444; }
  .tool-meta { font-size: 12px; color: var(--text-tertiary); }
  .tool-actions { display: flex; gap: 8px; margin-top: 4px; }
  .btn-view {
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-muted);
    border-radius: 6px;
    text-decoration: none;
    transition: background 150ms ease;
  }
  .btn-view:hover { background: var(--accent); color: white; }
</style>
