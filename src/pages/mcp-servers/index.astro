---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FilterSidebar from '../../components/FilterSidebar.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl } from '../../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';
const servers = await getCollection('mcp-servers');

const priceFilters = [
  { id: 'all', label: isZh ? '全部' : 'All' },
  { id: 'free', label: isZh ? '免费' : 'Free', count: servers.filter(s => s.data.price === 'free').length },
  { id: 'paid', label: isZh ? '付费' : 'Paid', count: servers.filter(s => s.data.price === 'paid').length },
];
---

<BaseLayout title={isZh ? 'MCP Servers - mcpkit.run' : 'MCP Servers - mcpkit.run'}>
  <Header />

  <main class="main">
    <div class="page-header">
      <div class="container">
        <h1 class="page-title">{isZh ? 'MCP Servers' : 'MCP Servers'}</h1>
        <p class="page-desc">
          {isZh
            ? `连接 AI Agent 与各类服务的桥梁，共 ${servers.length} 个工具`
            : `Bridge AI Agents to external services — ${servers.length} tools`}
        </p>
      </div>
    </div>

    <div class="container">
      <div class="layout">
        <FilterSidebar title={isZh ? '价格' : 'Price'} options={priceFilters} />
        <div class="tools-grid">
          {servers.map(server => (
            <ToolCard {...server.data} slug={server.slug} />
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main { min-height: calc(100vh - 60px); }
  .page-header { border-bottom: 1px solid var(--border-color); padding: 40px 0 32px; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .page-title { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
  .page-desc { font-size: 16px; color: var(--text-secondary); }
  .layout { display: flex; gap: 40px; padding: 32px 0 64px; align-items: flex-start; }
  .tools-grid { flex: 1; display: grid; grid-template-columns: repeat(1, 1fr); gap: 16px; }
  @media (min-width: 640px) { .tools-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .tools-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
