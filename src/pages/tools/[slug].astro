---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import PriceBadge from '../../components/PriceBadge.astro';
import InstallCommand from '../../components/InstallCommand.astro';
import TagList from '../../components/TagList.astro';
import RadarChart from '../../components/RadarChart.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl, t } from '../../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const i18n = t(locale);
const isZh = locale === 'zh';

export async function getStaticPaths() {
  const mcpServers = await getCollection('mcp-servers');
  const aiTools = await getCollection('ai-tools');
  const deployment = await getCollection('deployment');

  const allTools = [...mcpServers, ...aiTools, ...deployment];
  return allTools.map(entry => ({
    params: { slug: entry.id.replace(/\.(md|mdx)$/, '') },
    props: { entry, allTools },
  }));
}

const { entry, allTools } = Astro.props;

const related = allTools
  .filter(t => t.id.replace(/\.(md|mdx)$/, '') !== entry.id.replace(/\.(md|mdx)$/, '') && t.data.category === entry.data.category)
  .slice(0, 2);

const categoryMap: Record<string, string> = {
  'mcp-servers': isZh ? 'MCP 服务器' : 'MCP Servers',
  'ai-tools': isZh ? 'AI 工具' : 'AI Tools',
  'deployment': isZh ? '部署' : 'Deployment',
};
const categorySlug: Record<string, string> = {
  'mcp-servers': 'mcp-servers',
  'ai-tools': 'ai-tools',
  'deployment': 'deployment',
};
const category = entry.data.category || 'mcp-servers';
---

<BaseLayout title={`${entry.data.title} - mcpkit.run`} description={entry.data.description}>
  <main class="container">
    <nav class="breadcrumb">
      <a href={`/?lang=${locale}`}>{i18n.detail.breadcrumbHome}</a>
      <span class="sep">›</span>
      <a href={`/${categorySlug[category]}/?lang=${locale}`}>
        {categoryMap[category] || category}
      </a>
      <span class="sep">›</span>
      <span>{entry.data.title}</span>
    </nav>

    <div class="tool-header">
      <div class="logo-wrap">
        {entry.data.logo ? (
          <img src={entry.data.logo} alt={entry.data.title} class="tool-logo" />
        ) : (
          <div class="logo-placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </div>
        )}
      </div>
      <div class="header-info">
        <h1 class="tool-title">{entry.data.title}</h1>
        <div class="meta-row">
          <PriceBadge price={entry.data.price} />
          <TagList tags={entry.data.tags || []} />
        </div>
      </div>
    </div>

    <p class="tool-desc">{entry.data.description}</p>

    <div class="section radar-section">
      <h3>{isZh ? '四维评测' : 'Quality Score'}</h3>
      <RadarChart toolSlug={entry.id.replace(/\.(md|mdx)$/, '')} />
    </div>

    <div class="two-col">
      <div class="left-col">
        {entry.data.scenarios?.length && (
          <div class="section">
            <h3>{i18n.detail.useCases}</h3>
            <ul class="scenario-list">
              {entry.data.scenarios.map((s: string) => <li>{s}</li>)}
            </ul>
          </div>
        )}

        {entry.data.config && (
          <div class="section">
            <h3>{i18n.detail.installConfig}</h3>
            <InstallCommand command={entry.data.config} />
          </div>
        )}
      </div>

      {related.length > 0 && (
        <div class="right-col">
          <h3>{i18n.detail.relatedTools}</h3>
          <div class="related-grid">
            {related.map(t => (
              <ToolCard {...t.data} slug={t.id.replace(/\.(md|mdx)$/, '')} />
            ))}
          </div>
        </div>
      )}
    </div>

    <div class="tool-actions">
      <a href={entry.data.website} target="_blank" rel="noopener" class="btn-primary">
        {i18n.detail.visitSite}
      </a>
    </div>
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 1024px;
    margin: 0 auto;
    padding: 32px 24px 64px;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-muted);
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .breadcrumb a:hover { color: var(--text-secondary); }
  .sep { color: var(--text-muted); }
  .tool-header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 24px;
  }
  .logo-wrap {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tool-logo { width: 100%; height: 100%; object-fit: contain; }
  .logo-placeholder { color: var(--text-muted); }
  .header-info { flex: 1; min-width: 0; }
  .tool-title { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; }
  .meta-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .tool-desc { font-size: 16px; color: var(--text-secondary); line-height: 1.7; margin-bottom: 40px; }
  .two-col { display: grid; grid-template-columns: 1fr; gap: 40px; margin-bottom: 40px; }
  @media (min-width: 768px) { .two-col { grid-template-columns: 1fr 1fr; } }
  .section { margin-bottom: 32px; }
  .section h3 { font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 12px; }
  .scenario-list { list-style: disc; list-style-position: inside; color: var(--text-secondary); font-size: 14px; line-height: 2; }
  .right-col h3 { font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 16px; }
  .related-grid { display: flex; flex-direction: column; gap: 12px; }
  .tool-actions { margin-top: 40px; }
  .radar-section { margin-bottom: 32px; }
  .radar-section h3 { font-size: 16px; font-weight: 600; color: var(--text-primary); margin-bottom: 16px; }
  .btn-primary {
    display: inline-block;
    padding: 14px 24px;
    font-size: 16px;
    font-weight: 600;
    color: white;
    background: var(--accent);
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 150ms ease;
  }
  .btn-primary:hover { background: var(--accent-hover); }
</style>
