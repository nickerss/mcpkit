---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RadarChart from '../../components/RadarChart.astro';
import DifficultyTab from '../../components/DifficultyTab.astro';
import CertificationBadge from '../../components/CertificationBadge.astro';
import InstallCommand from '../../components/InstallCommand.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl } from '../../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';

export async function getStaticPaths() {
  const kits = await getCollection('kits');
  return kits.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const kit = entry.data;

// Read ?level= param (default starter)
const url = new URL(Astro.request.url);
const level = (url.searchParams.get('level') || 'starter') as 'starter' | 'pro' | 'enterprise';
const currentLevel = level === 'pro' || level === 'enterprise' ? level : 'starter';

const levelData = kit.levels[currentLevel];

// Build baseUrl from page URL
const baseUrl = `/kits/${entry.slug}/`;

// Fetch all tool entries from all 3 collections
const [mcpServers, aiTools, deploymentTools] = await Promise.all([
  getCollection('mcp-servers'),
  getCollection('ai-tools'),
  getCollection('deployment'),
]);
const allTools = [...mcpServers, ...aiTools, ...deploymentTools];

// Build map: tool name → entry
const toolMap = new Map(allTools.map(t => [t.data.name, t]));

// Real eval data fallback
function getEval(toolName: string) {
  const e = toolMap.get(toolName)?.data.evaluation;
  if (e) return e;
  const seed = toolName.length * 1.7;
  return {
    easeOfUse: 3 + (seed % 20) / 10,
    security: 3.5 + (seed % 15) / 10,
    activity: 3 + (seed % 25) / 10,
    scenarioFit: 3.5 + (seed % 20) / 10,
  };
}

// Kit-level aggregate scores (average across tools for current level)
function avgScores(tools: string[]) {
  const evals = tools.map(getEval);
  return {
    easeOfUse: evals.reduce((s, e) => s + e.easeOfUse, 0) / evals.length,
    security: evals.reduce((s, e) => s + e.security, 0) / evals.length,
    activity: evals.reduce((s, e) => s + e.activity, 0) / evals.length,
    scenarioFit: evals.reduce((s, e) => s + e.scenarioFit, 0) / evals.length,
  };
}

const aggregate = avgScores(levelData.tools);
const kitOverall = parseFloat((aggregate.easeOfUse * 0.3 + aggregate.security * 0.25 + aggregate.activity * 0.2 + aggregate.scenarioFit * 0.25).toFixed(1));

const levelLabels = { starter: 'Starter', pro: 'Pro', enterprise: 'Enterprise' };
---

<BaseLayout title={`${kit.title} - mcpkit.run`} description={kit.description}>
  <Header />

  <main>
    <!-- Kit Hero -->
    <section class="kit-hero" style={`--kit-color: ${kit.color}`}>
      <div class="hero-bg"></div>
      <div class="hero-content">
        <div class="kit-icon-wrap">
          <span class="kit-icon" set:html={kit.icon === 'rocket' ? '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>' : kit.icon === 'bot' ? '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>' : kit.icon === 'search' ? '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>' : kit.icon === 'zap' ? '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>' : '<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a-2 2 0 0 1-3.46 0"/></svg>'} />
        </div>
        <h1 class="kit-title">{kit.title}</h1>
        <p class="kit-desc">{kit.description}</p>
        <div class="kit-meta">
          <CertificationBadge status="certified" />
        </div>
      </div>
    </section>

    <!-- Kit Info -->
    <section class="kit-info-section">
      <div class="container">
        <p class="kit-tagline-text en-hide">{kit.tagline?.zh || ''}</p><p class="kit-tagline-text zh-hide">{kit.tagline?.en || ''}</p>
        {kit.pros && kit.pros.zh && kit.pros.zh.length > 0 && (
          <div class="kit-pros">
            <h3 class="en-hide">✨ 优势</h3><h3 class="zh-hide">✨ Pros</h3>
            <ul>
              {kit.pros?.zh.map((p) => (<li class="en-hide">{p}</li>))}{kit.pros?.en.map((p) => (<li class="zh-hide">{p}</li>))}
            </ul>
          </div>
        )}
        {kit.cons && kit.cons.zh && kit.cons.zh.length > 0 && (
          <div class="kit-cons">
            <h3 class="en-hide">⚠️ 局限</h3><h3 class="zh-hide">⚠️ Considerations</h3>
            <ul>
              {kit.cons?.zh.map((c) => (<li class="en-hide">{c}</li>))}{kit.cons?.en.map((c) => (<li class="zh-hide">{c}</li>))}
            </ul>
          </div>
        )}
        {kit.targetAudience && kit.targetAudience.zh && kit.targetAudience.zh.length > 0 && (
          <p class="kit-target"><span class="en-hide">👥 适合: {kit.targetAudience?.zh}</span><span class="zh-hide">👥 For: {kit.targetAudience?.en}</span></p>
        )}
      </div>
    </section>

    <!-- Difficulty Tabs + Content -->
    <section class="kit-body">
      <div class="container">
        <DifficultyTab current={currentLevel} baseUrl={baseUrl} />

        <div class="kit-layout">
          <!-- Main: Tool list -->
          <div class="tool-list">
            <p class="level-desc">{levelData.description}</p>
            <div class="tools-grid">
              {levelData.tools.map(toolName => {
                const toolEntry = toolMap.get(toolName);
                const eval_ = getEval(toolName);
                const overall = parseFloat((eval_.easeOfUse * 0.3 + eval_.security * 0.25 + eval_.activity * 0.2 + eval_.scenarioFit * 0.25).toFixed(1));
                const certStatus = (toolEntry?.data.certificationStatus as any) || 'pending';
                const installCmd = toolEntry?.data.installCommand;
                const envVars = toolEntry?.data.envVars;
                const configExample = toolEntry?.data.configExample;

                return (
                  <div class="tool-card">
                    <div class="tool-card-header">
                      <div class="tool-name-row">
                        <span class="tool-name">{toolName}</span>
                        <CertificationBadge status={certStatus} size="sm" />
                      </div>
                      {toolEntry && (
                        <p class="tool-desc">{toolEntry.data.description}</p>
                      )}
                    </div>

                    {installCmd && (
                      <div class="tool-install">
                        <InstallCommand command={installCmd} />
                      </div>
                    )}

                    {envVars && envVars.length > 0 && (
                      <div class="tool-envvars">
                        <span class="env-label">{isZh ? '环境变量' : 'Env Vars'}:</span>
                        <code class="env-list">{envVars.join(', ')}</code>
                      </div>
                    )}

                    <div class="tool-radar">
                      <RadarChart
                        easeOfUse={eval_.easeOfUse}
                        security={eval_.security}
                        activity={eval_.activity}
                        scenarioFit={eval_.scenarioFit}
                        overall={overall}
                        size={180}
                        kitColor={kit.color}
                      />
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Sidebar: Kit aggregate RadarChart -->
          <aside class="kit-sidebar">
            <div class="sidebar-card">
              <h3 class="sidebar-title">{isZh ? '套件综合评分' : 'Kit Aggregate Score'}</h3>
              <RadarChart
                easeOfUse={aggregate.easeOfUse}
                security={aggregate.security}
                activity={aggregate.activity}
                scenarioFit={aggregate.scenarioFit}
                overall={kitOverall}
                size={280}
                kitColor={kit.color}
              />
              <div class="sidebar-rating">
                <span class="rating-label">{isZh ? '综合评分' : 'Overall Rating'}</span>
                <span class="rating-val">⭐ {kitOverall.toFixed(1)}</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .kit-hero {
    position: relative;
    padding: 80px 24px 64px;
    text-align: center;
    overflow: hidden;
    background: color-mix(in srgb, var(--kit-color) 8%, transparent);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% -20%, color-mix(in srgb, var(--kit-color) 30%, transparent), transparent);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .kit-icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: color-mix(in srgb, var(--kit-color) 20%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }
  .kit-icon { font-size: 40px; }
  .kit-title {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 12px;
  }
  .kit-desc {
    font-size: 16px;
    color: var(--text-secondary);
    margin-bottom: 20px;
    line-height: 1.6;
  }
  .kit-meta {
    display: flex;
    justify-content: center;
    gap: 8px;
  }
  .kit-body {
    padding: 48px 0 80px;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .kit-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 32px;
    margin-top: 32px;
  }
  .tool-list {
    min-width: 0;
  }
  .level-desc {
    font-size: 15px;
    color: var(--text-secondary);
    margin-bottom: 24px;
    line-height: 1.6;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
  }
  .tool-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .tool-card-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .tool-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .tool-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .tool-desc {
    font-size: 13px;
    color: var(--text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tool-install {
    font-size: 13px;
  }
  .tool-envvars {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .env-label {
    font-size: 12px;
    color: var(--text-muted);
    font-weight: 600;
  }
  .env-list {
    font-size: 11px;
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    padding: 2px 8px;
    border-radius: 4px;
    font-family: monospace;
  }
  .tool-radar {
    display: flex;
    justify-content: center;
  }
  .kit-sidebar {
    position: sticky;
    top: 24px;
    align-self: start;
  }
  .sidebar-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .sidebar-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    text-align: center;
  }
  .sidebar-rating {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  .rating-label {
    font-size: 12px;
    color: var(--text-muted);
  }
  .rating-val {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
  }
  @media (max-width: 900px) {
    .kit-layout {
      grid-template-columns: 1fr;
    }
    .kit-sidebar {
      position: static;
    }
  }

.kit-info-section {
    padding: 0 0 32px;
  }
  .kit-tagline-text {
    font-size: 16px;
    color: var(--text-secondary);
    text-align: center;
    margin-bottom: 24px;
    line-height: 1.6;
  }
  .kit-pros, .kit-cons {
    margin-bottom: 16px;
  }
  .kit-pros h3, .kit-cons h3 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text-primary);
  }
  .kit-pros ul, .kit-cons ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .kit-pros li, .kit-cons li {
    font-size: 14px;
    color: var(--text-secondary);
    padding-left: 16px;
    position: relative;
  }
  .kit-pros li::before { content: '+'; position: absolute; left: 0; color: #22c55e; font-weight: bold; }
  .kit-cons li::before { content: '-'; position: absolute; left: 0; color: #f59e0b; font-weight: bold; }
  .kit-target {
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .en-hide { display: none; }
  .zh-hide { }

  .en-hide { display: none; }
  .zh-hide { }
</style>