---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KitCard from '../components/KitCard.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';

// ── Kit cards data ──────────────────────────────────────────
const kitCards = [
  {
    kit: 'ship-a-saas',
    kitName: isZh ? '🚀 Ship a SaaS' : '🚀 Ship a SaaS',
    kitDesc: isZh ? '30分钟跑通一个 SaaS 产品并部署上线' : '30 minutes to a deployed SaaS product',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
    color: '#f97316',
    level: 'starter' as const,
    tools: ['github-mcp', 'supabase-mcp', 'cloudflare-pages-mcp'],
    rating: 4.7,
    certified: true,
    toolCount: 3,
    href: '/kits/ship-a-saas/',
  },
  {
    kit: 'ai-coding-agent',
    kitName: isZh ? '🤖 AI Coding Agent' : '🤖 AI Coding Agent',
    kitDesc: isZh ? '让 AI Agent 自动处理编码全流程' : 'Let AI Agents handle the full coding workflow',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    color: '#06b6d4',
    level: 'starter' as const,
    tools: ['claude-code', 'github-mcp', 'filesystem-mcp'],
    rating: 4.8,
    certified: true,
    toolCount: 3,
    href: '/kits/ai-coding-agent/',
  },
  {
    kit: 'rag-research',
    kitName: isZh ? '📊 RAG & Research' : '📊 RAG & Research',
    kitDesc: isZh ? '爬取网页 → 提取内容 → 向量存储 → 合成报告' : 'Crawl → Extract → Vector store → Synthesize reports',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>',
    color: '#8b5cf6',
    level: 'starter' as const,
    tools: ['brave-search-mcp', 'firecrawl-mcp', 'supabase-mcp'],
    rating: 4.5,
    certified: false,
    toolCount: 3,
    href: '/kits/rag-research/',
  },
  {
    kit: 'browser-automation',
    kitName: isZh ? '⚡ Browser Automation' : '⚡ Browser Automation',
    kitDesc: isZh ? '让 AI Agent 操作浏览器完成重复性 web 任务' : 'Automate repetitive web tasks with AI Agents',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
    color: '#eab308',
    level: 'starter' as const,
    tools: ['playwright-mcp', 'claude-code', 'filesystem-mcp'],
    rating: 4.6,
    certified: false,
    toolCount: 3,
    href: '/kits/browser-automation/',
  },
  {
    kit: 'devops-monitoring',
    kitName: isZh ? '🔔 DevOps & Monitoring' : '🔔 DevOps & Monitoring',
    kitDesc: isZh ? '让 AI Agent 自动监控 + 告警 + 修复' : 'Let AI Agents monitor + alert + fix automatically',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a-2 2 0 0 1-3.46 0"/></svg>',
    color: '#ef4444',
    level: 'starter' as const,
    tools: ['github-mcp', 'npm-mcp', 'slack-mcp'],
    rating: 4.4,
    certified: false,
    toolCount: 3,
    href: '/kits/devops-monitoring/',
  },
];

// ── Top tools: fetch all tools, sort by quality score ──────
const [mcpServers, aiTools, deploymentTools] = await Promise.all([
  getCollection('mcp-servers'),
  getCollection('ai-tools'),
  getCollection('deployment'),
]);

const allTools = [...mcpServers, ...aiTools, ...deploymentTools];

// Sort by evaluation overall (or quality_score fallback), take top 10
const scoredTools = allTools
  .filter(t => t.data.evaluation)
  .sort((a, b) => {
    const aScore = a.data.evaluation?.overall ?? (a.data.evaluation?.easeOfUse ?? 3);
    const bScore = b.data.evaluation?.overall ?? (b.data.evaluation?.easeOfUse ?? 3);
    return bScore - aScore;
  })
  .slice(0, 10);

// ── Testimonials ───────────────────────────────────────────
const testimonials = [
  {
    quote: isZh
      ? '以前配置这些要半天，现在 5 分钟搞定。Kit 把工具组合都配好了，直接用就行。'
      : 'Used to take half a day to configure this. Now 5 minutes flat. The Kit had all the tool combos pre-configured.',
    author: '@dev_lee',
    name: isZh ? '李明' : 'Ming Li',
    role: isZh ? '独立开发者' : 'Indie Developer',
    avatar: '👨‍💻',
  },
  {
    quote: isZh
      ? '认证标签让我放心集成陌生工具，不用担心安全问题了。'
      : 'The certified badge gives me confidence to integrate new tools without worrying about security.',
    author: '@sarah_dev',
    name: isZh ? 'Sarah Chen' : 'Sarah Chen',
    role: isZh ? '全栈工程师' : 'Full-Stack Engineer',
    avatar: '👩‍💻',
  },
  {
    quote: isZh
      ? 'RAG 研究套件让我一个人做了一整周的市场调研，工具链太顺了。'
      : 'The RAG Research Kit let me do a full week of market research solo. The tool chain was seamless.',
    author: '@research_maria',
    name: isZh ? 'Maria Wang' : 'Maria Wang',
    role: isZh ? '研究员' : 'Research Analyst',
    avatar: '🔬',
  },
];
---

<BaseLayout title={isZh ? 'MCPKIT — AI Agent 时代的一站式 MCP 工具包发现与认证平台' : 'MCPKIT — One-Stop MCP Toolkit Discovery & Verification Platform for the AI Agent Era'}>
  <Header />

  <main>
    <!-- ═══ HERO ════════════════════════════════════════════════ -->
    <section class="hero">
      <div class="hero-bg-grid"></div>
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          <span class="en-hide">AI Agent Toolkit Discovery & Verification Platform</span>
          <span class="zh-show">AI Agent 工具包发现与认证平台</span>
        </div>
        <h1 class="hero-title">
          <span class="en-hide">Trusted Lego-style Toolkit</span>
          <span class="zh-show">为你的 AI Agent</span><br/>
          <span class="gradient-text">
            <span class="en-hide">for Your AI Agent</span>
            <span class="zh-show">装上可信的乐高式工具包</span>
          </span>
        </h1>
        <p class="hero-subtitle">
          <span class="en-hide">Discover · Verify · Combine — all in one place.</span>
          <span class="zh-show">发现 · 认证 · 组合，一站搞定。</span>
        </p>

        <!-- Search -->
        <form class="search-form" action={`/search/?lang=${locale}`} method="get">
          <div class="search-wrap">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              type="text"
              name="q"
              class="search-input"
              placeholder={isZh ? '输入场景或工具名称...' : 'Search scenarios or tool name...'}
              autocomplete="off"
            />
            <button type="submit" class="search-btn">
              {isZh ? '开始探索' : 'Explore'}
            </button>
          </div>
        </form>

        <!-- Hot Tags -->
        <div class="hot-tags">
          <span class="hot-tags-label">{isZh ? '热门：' : 'Hot:'}</span>
          <a href="/kits/ship-a-saas/" class="hot-tag">#Ship a SaaS</a>
          <a href="/kits/ai-coding-agent/" class="hot-tag">#AI Coding</a>
          <a href="/kits/rag-research/" class="hot-tag">#RAG Research</a>
          <a href="/kits/browser-automation/" class="hot-tag">#Browser Automation</a>
          <a href="/kits/devops-monitoring/" class="hot-tag">#DevOps</a>
        </div>
      </div>
    </section>

    <!-- ═══ FEATURED KITS ════════════════════════════════════ -->
    <section class="kits-section">
      <div class="container">
        <div class="section-header">
          <div class="section-heading-wrap">
            <span class="heading-accent"></span>
            <h2 class="section-heading" data-i18n="home.featured">{isZh ? '热门场景 Kits' : 'Featured Kits'}</h2>
          </div>
          <a href="/kits/" class="view-all-link">{isZh ? '查看全部 Kits →' : 'View all Kits →'}</a>
        </div>

        <div class="kits-grid">
          {kitCards.map(card => (
            <KitCard {...card} />
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ TOP RATED TOOLS ═════════════════════════════════ -->
    <section class="top-tools-section">
      <div class="container">
        <div class="section-header">
          <div class="section-heading-wrap">
            <span class="heading-accent"></span>
            <h2 class="section-heading">{isZh ? '最高评分工具' : 'Top Rated Tools'}</h2>
          </div>
          <a href="/ai-tools/" class="view-all-link">{isZh ? '查看全部 →' : 'View all →'}</a>
        </div>

        <div class="tools-scroll">
          <div class="tools-scroll-inner">
            {scoredTools.map(tool => {
              const eval_ = tool.data.evaluation;
              const overall = eval_?.overall ?? 4.0;
              const certStatus = tool.data.certificationStatus ?? 'pending';
              return (
                <div class="tool-scroll-card">
                  <div class="tool-scroll-header">
                    <span class={`cert-dot ${certStatus === 'certified' ? 'cert' : certStatus === 'recommended' ? 'rec' : 'pend'}`}></span>
                    <span class="tool-name">{tool.data.title}</span>
                  </div>
                  <p class="tool-brief">{tool.data.description?.slice(0, 80) ?? ''}...</p>
                  <div class="tool-score-row">
                    <span class="star-row">{'★'.repeat(Math.round(overall))}{'☆'.repeat(5 - Math.round(overall))}</span>
                    <span class="score-num">{overall.toFixed(1)}</span>
                  </div>
                  <a href={`/tools/${tool.data.name}/`} class="tool-view-btn">
                    {isZh ? '查看详情' : 'View Details'}
                  </a>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ TESTIMONIALS ════════════════════════════════════ -->
    <section class="testimonials-section">
      <div class="container">
        <div class="section-header">
          <div class="section-heading-wrap">
            <span class="heading-accent"></span>
            <h2 class="section-heading">{isZh ? '值得信赖的声音' : 'Trusted by Developers'}</h2>
          </div>
        </div>

        <div class="testimonials-grid">
          {testimonials.map(t => (
            <div class="testimonial-card">
              <div class="quote-mark">"</div>
              <p class="testimonial-text">{t.quote}</p>
              <div class="testimonial-author">
                <span class="author-avatar">{t.avatar}</span>
                <div class="author-info">
                  <span class="author-name">{t.name}</span>
                  <span class="author-role">{t.role}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    padding: 96px 24px 72px;
    text-align: center;
    overflow: hidden;
  }
  .hero-bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,0.18), transparent),
      radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0);
    background-size: 100% 100%, 32px 32px;
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 760px;
    margin: 0 auto;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: rgba(139,92,246,0.12);
    border: 1px solid rgba(139,92,246,0.3);
    border-radius: 9999px;
    font-size: 12px;
    color: #a78bfa;
    margin-bottom: 24px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #8b5cf6;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .hero-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 16px;
    color: var(--text-primary);
  }
  .gradient-text {
    background: linear-gradient(135deg, #8b5cf6, #06b6d4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-subtitle {
    font-size: 18px;
    color: var(--text-secondary);
    margin-bottom: 36px;
    line-height: 1.6;
  }

  /* Search */
  .search-form { max-width: 600px; margin: 0 auto; }
  .search-wrap {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border-default);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 200ms ease;
  }
  .search-wrap:focus-within { border-color: var(--accent); }
  .search-icon {
    position: absolute;
    left: 18px;
    color: var(--text-tertiary);
    pointer-events: none;
    flex-shrink: 0;
  }
  .search-input {
    flex: 1;
    padding: 16px 16px 16px 50px;
    font-size: 16px;
    color: var(--text-primary);
    background: transparent;
    border: none;
    outline: none;
  }
  .search-input::placeholder { color: var(--text-tertiary); }
  .search-btn {
    padding: 12px 24px;
    margin: 6px;
    font-size: 14px;
    font-weight: 600;
    color: white;
    background: var(--accent);
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 150ms ease;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .search-btn:hover { background: var(--accent-hover); }

  /* Hot Tags */
  .hot-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
  }
  .hot-tags-label {
    font-size: 13px;
    color: var(--text-tertiary);
    font-weight: 500;
  }
  .hot-tag {
    display: inline-block;
    padding: 5px 12px;
    font-size: 13px;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 9999px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .hot-tag:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(139,92,246,0.08);
  }

  /* ── Shared ── */
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
  }
  .section-heading-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .heading-accent {
    display: inline-block;
    width: 4px;
    height: 24px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .section-heading {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .view-all-link {
    font-size: 14px;
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .view-all-link:hover { color: var(--accent); }

  /* ── Kits ── */
  .kits-section {
    padding: 64px 0;
  }
  .kits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  @media (min-width: 1200px) {
    .kits-grid { grid-template-columns: repeat(5, 1fr); }
  }

  /* ── Top Tools ── */
  .top-tools-section {
    padding: 64px 0;
    background: var(--bg-secondary);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }
  .tools-scroll {
    overflow-x: auto;
    padding-bottom: 12px;
    scrollbar-width: thin;
    scrollbar-color: var(--border-default) transparent;
  }
  .tools-scroll::-webkit-scrollbar { height: 4px; }
  .tools-scroll::-webkit-scrollbar-track { background: transparent; }
  .tools-scroll::-webkit-scrollbar-thumb { background: var(--border-default); border-radius: 2px; }
  .tools-scroll-inner {
    display: flex;
    gap: 16px;
    min-width: max-content;
  }
  .tool-scroll-card {
    width: 220px;
    flex-shrink: 0;
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .tool-scroll-card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 20px rgba(139,92,246,0.12);
  }
  .tool-scroll-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .cert-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .cert-dot.cert { background: #f59e0b; }
  .cert-dot.rec { background: var(--accent); }
  .cert-dot.pend { background: var(--text-tertiary); }
  .tool-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .tool-brief {
    font-size: 12px;
    color: var(--text-tertiary);
    line-height: 1.5;
    flex: 1;
  }
  .tool-score-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .star-row {
    font-size: 12px;
    color: #f59e0b;
    letter-spacing: -1px;
  }
  .score-num {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .tool-view-btn {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
    transition: opacity 150ms ease;
  }
  .tool-view-btn:hover { opacity: 0.7; }

  /* ── Testimonials ── */
  .testimonials-section {
    padding: 64px 0 96px;
  }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }
  .testimonial-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    transition: border-color 200ms ease;
  }
  .testimonial-card:hover { border-color: var(--border-default); }
  .quote-mark {
    font-size: 48px;
    line-height: 1;
    color: var(--accent);
    opacity: 0.3;
    font-family: Georgia, serif;
    font-weight: 700;
    margin-bottom: -8px;
  }
  .testimonial-text {
    font-size: 15px;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }
  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .author-avatar {
    font-size: 32px;
  }
  .author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .author-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }
  .author-role {
    font-size: 12px;
    color: var(--text-tertiary);
  }
</style>
