---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import CategoryCard from '../components/CategoryCard.astro';
import FeaturedSection from '../components/FeaturedSection.astro';
import ToolCard from '../components/ToolCard.astro';
import { getCollection } from 'astro:content';

const mcpServers = await getCollection('mcp-servers');
const aiTools = await getCollection('ai-tools');
const deployment = await getCollection('deployment');

const allTools = [...mcpServers, ...aiTools, ...deployment];
const featured = allTools.filter(t => t.data.featured).slice(0, 5);
const latest = allTools
  .sort((a, b) => new Date(b.data.submittedAt) - new Date(a.data.submittedAt))
  .slice(0, 9);
---

<BaseLayout title="mcpkit.run - AI Agent 开发者工具目录">
  <Header />

  <main>
    <HeroSection />

    <section class="categories">
      <div class="container">
        <div class="category-cards">
          <CategoryCard name="MCP Servers" slug="mcp-servers" icon="database" count={mcpServers.length} description="连接 AI Agent 与各类服务的桥梁" />
          <CategoryCard name="AI Coding Tools" slug="ai-tools" icon="code-2" count={aiTools.length} description="AI 驱动的代码编辑器和 CLI 工具" />
          <CategoryCard name="工作流 & 部署" slug="deployment" icon="cloud" count={deployment.length} description="部署、数据库、支付一站式工具" />
        </div>
      </div>
    </section>

    {featured.length > 0 && (
      <section class="featured-section">
        <FeaturedSection tools={featured} title="编辑精选" />
      </section>
    )}

    {latest.length > 0 && (
      <section class="latest-section">
        <div class="container">
          <h2 class="section-title">最新收录</h2>
          <div class="tools-grid">
            {latest.map(tool => (
              <ToolCard {...tool.data} slug={tool.slug} />
            ))}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

<style>
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .categories {
    padding: 48px 0;
  }
  .category-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .featured-section {
    padding: 48px 0;
  }
  .latest-section {
    padding: 48px 0 80px;
  }
  .section-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 16px;
  }
  @media (min-width: 640px) {
    .tools-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .tools-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
