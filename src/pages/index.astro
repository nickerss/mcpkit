---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import KitCard from '../components/KitCard.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';

const kitCards = [
  {
    kit: 'ship-a-saas',
    kitName: 'Ship a SaaS',
    kitDesc: isZh
      ? '从零开始构建并部署一个 SaaS 产品，30分钟跑通'
      : 'Build and deploy a SaaS from scratch in 30 minutes',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
    color: '#f97316',
    level: 'starter' as const,
    tools: ['github-mcp', 'supabase-mcp', 'cloudflare-pages-mcp'],
    rating: 4.7,
    certified: true,
    toolCount: 3,
    href: '/kits/ship-a-saas/',
  },
  {
    kit: 'ai-coding-agent',
    kitName: 'AI Coding Agent',
    kitDesc: isZh
      ? '让 AI Agent 自动处理编码全流程——不只是写代码，是真正能干活的 Agent'
      : 'Let AI Agents handle the full coding workflow — not just writing code, but actually getting things done',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>',
    color: '#06b6d4',
    level: 'starter' as const,
    tools: ['claude-code', 'github-mcp', 'filesystem-mcp'],
    rating: 4.8,
    certified: true,
    toolCount: 3,
    href: '/kits/ai-coding-agent/',
  },
  {
    kit: 'rag-research',
    kitName: 'RAG & Research',
    kitDesc: isZh
      ? '让 AI Agent 做深度研究——爬取网页 → 提取内容 → 存入向量数据库 → 合成报告'
      : 'Deep research with AI Agents — crawl web → extract content → store in vector DB → synthesize reports',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>',
    color: '#8b5cf6',
    level: 'starter' as const,
    tools: ['brave-search-mcp', 'firecrawl-mcp', 'supabase-mcp'],
    rating: 4.5,
    certified: false,
    toolCount: 3,
    href: '/kits/rag-research/',
  },
  {
    kit: 'browser-automation',
    kitName: 'Browser Automation',
    kitDesc: isZh
      ? '让 AI Agent 操作浏览器完成重复性 web 任务'
      : 'Let AI Agents control browsers to automate repetitive web tasks',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#eab308" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
    color: '#eab308',
    level: 'starter' as const,
    tools: ['playwright-mcp', 'claude-code', 'filesystem-mcp'],
    rating: 4.6,
    certified: false,
    toolCount: 3,
    href: '/kits/browser-automation/',
  },
  {
    kit: 'devops-monitoring',
    kitName: 'DevOps & Monitoring',
    kitDesc: isZh
      ? '让 AI Agent 自动监控 + 告警 + 修复'
      : 'Let AI Agents automatically monitor + alert + fix issues',
    icon: '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a-2 2 0 0 1-3.46 0"/></svg>',
    color: '#ef4444',
    level: 'starter' as const,
    tools: ['github-mcp', 'npm-mcp', 'slack-mcp'],
    rating: 4.4,
    certified: false,
    toolCount: 3,
    href: '/kits/devops-monitoring/',
  },
];
---

<BaseLayout title={isZh ? 'MCPKIT — AI Agent 开发者工具目录' : 'MCPKIT — AI Agent Tools for Independent Developers'}>
  <Header />

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="hero-content">
        <h1 class="hero-title">
          {isZh ? '独立开发者的' : 'Your AI Agent'}<br/>
          <span class="gradient-text">{isZh ? 'AI Agent 工具箱' : 'Toolkit'}</span>
        </h1>
        <p class="hero-subtitle">
          {isZh ? 'Kit 化工具套件 · 精选认证 · 四维评测' : 'Kit-based tool combos · Verified · Rated'}
        </p>
        <form class="search-form" action={`/search/?lang=${locale}`} method="get">
          <div class="search-wrap">
            <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              type="text"
              name="q"
              class="search-input"
              placeholder={isZh ? '输入场景或工具名称...' : 'Search tools...'}
              autocomplete="off"
            />
          </div>
        </form>
        <!-- Hot Tags -->
        <div class="hot-tags">
          <a href="/mcp-servers/" class="hot-tag">#电商运营</a>
          <a href="/mcp-servers/" class="hot-tag">#DevOps</a>
          <a href="/mcp-servers/" class="hot-tag">#内容创作</a>
          <a href="/mcp-servers/" class="hot-tag">#个人理财</a>
          <a href="/mcp-servers/" class="hot-tag">#数据采集</a>
          <a href="/mcp-servers/" class="hot-tag">#AI编程</a>
          <a href="/mcp-servers/" class="hot-tag">#浏览器自动化</a>
          <a href="/mcp-servers/" class="hot-tag">#数据库</a>
        </div>
      </div>
    </section>

    <!-- Kit Cards Grid -->
    <section class="kits-section">
      <div class="container">
        <h2 class="section-heading">
          <span class="heading-accent"></span>
          {isZh ? '热门场景 Kits' : 'Popular Kits'}
        </h2>
        <div class="kits-grid">
          {kitCards.map(card => (
            <KitCard {...card} />
          ))}
        </div>

        <div class="view-all-wrap">
          <a href="/mcp-servers/" class="view-all-link">{isZh ? '查看全部工具 →' : 'View all tools →'}</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding: 80px 24px 64px;
    text-align: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.15), transparent);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 12px;
    color: var(--text-primary);
  }
  .hero-subtitle {
    font-size: 18px;
    color: var(--text-secondary);
    margin-bottom: 32px;
  }
  .search-form { max-width: 560px; margin: 0 auto; }
  .search-wrap { position: relative; display: flex; align-items: center; }
  .search-icon {
    position: absolute;
    left: 16px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 16px 16px 16px 48px;
    font-size: 16px;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    outline: none;
    transition: border-color 200ms ease;
  }
  .search-input::placeholder { color: var(--text-muted); }
  .search-input:focus { border-color: var(--accent); }

  /* Hot Tags */
  .hot-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .hot-tag {
    display: inline-block;
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-subtle);
    border-radius: 9999px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .hot-tag:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-muted);
  }

  .kits-section {
    padding: 48px 0 80px;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .section-heading {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 24px;
  }
  .heading-accent {
    display: inline-block;
    width: 4px;
    height: 24px;
    background: var(--accent);
    border-radius: 2px;
  }
  .kits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
  }
  @media (min-width: 1200px) {
    .kits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .view-all-link {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .view-all-link:hover {
    color: var(--accent);
  }
  .view-all-wrap {
    text-align: center;
    margin-top: 32px;
  }
</style>
