---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import { getCollection } from 'astro:content';
import { getLocaleFromUrl } from '../../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';
const tools = await getCollection('ai-tools');
---

<BaseLayout title={isZh ? 'AI 编码工具 — MCPKIT' : 'AI Coding Tools — MCPKIT'}>
  <Header />

  <main class="main">
    <div class="page-header">
      <div class="container">
        <h1 class="page-title">{isZh ? 'AI 编码工具' : 'AI Coding Tools'}</h1>
        <p class="page-desc">
          {isZh ? 'AI 驱动的代码编辑器、CLI 工具和开发环境，加速你的开发工作流。' : 'AI-powered code editors, CLI tools, and dev environments to accelerate your development workflow.'}
        </p>
      </div>
    </div>

    <div class="container">
      <div class="tools-grid">
        {tools.map(tool => (
          <ToolCard {...tool.data} slug={tool.id.replace(/\.(md|mdx)$/, '')} />
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main { min-height: calc(100vh - 60px); }
  .page-header { border-bottom: 1px solid var(--border-color); padding: 40px 0 32px; }
  .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
  .page-title { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
  .page-desc { color: var(--text-secondary); font-size: 16px; }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    padding: 40px 0 80px;
  }
</style>
