---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';

const plans = [
  {
    name: isZh ? '免费版' : 'Free',
    price: '$0',
    period: isZh ? '/月' : '/mo',
    recommended: false,
    description: isZh ? '适合个人探索和学习' : 'For individuals exploring and learning',
    features: [
      { text: isZh ? '5 个工具收录' : '5 tool listings', included: true },
      { text: isZh ? '基础工具认证' : 'Basic tool verification', included: true },
      { text: isZh ? '社区支持' : 'Community support', included: true },
      { text: isZh ? 'Kit 市场访问' : 'Kit marketplace access', included: true },
      { text: isZh ? '高级分析面板' : 'Advanced analytics', included: false },
      { text: isZh ? '付费推广 (CPC/置顶)' : 'Paid promotion (CPC/featured)', included: false },
      { text: isZh ? '专属客户支持' : 'Dedicated support', included: false },
    ],
    cta: isZh ? '开始使用' : 'Get Started',
    ctaHref: '/submit/',
  },
  {
    name: isZh ? '专业版' : 'Pro',
    price: '$29',
    period: isZh ? '/月' : '/mo',
    recommended: true,
    description: isZh ? '适合独立开发者和初创团队' : 'For indie devs and small teams',
    features: [
      { text: isZh ? '50 个工具收录' : '50 tool listings', included: true },
      { text: isZh ? '高级工具认证' : 'Advanced verification', included: true },
      { text: isZh ? '邮件支持' : 'Email support', included: true },
      { text: isZh ? 'Kit 市场访问' : 'Kit marketplace access', included: true },
      { text: isZh ? '高级分析面板' : 'Advanced analytics', included: true },
      { text: isZh ? '付费推广 (CPC/置顶)' : 'Paid promotion (CPC/featured)', included: true },
      { text: isZh ? '专属客户支持' : 'Dedicated support', included: false },
    ],
    cta: isZh ? '立即升级' : 'Upgrade Now',
    ctaHref: '/api/stripe/checkout?plan=pro',
  },
  {
    name: isZh ? '企业版' : 'Enterprise',
    price: '$99',
    period: isZh ? '/月' : '/mo',
    recommended: false,
    description: isZh ? '适合规模化的团队和组织' : 'For scaled teams and organizations',
    features: [
      { text: isZh ? '无限工具收录' : 'Unlimited tool listings', included: true },
      { text: isZh ? '企业级认证' : 'Enterprise verification', included: true },
      { text: isZh ? '专属客户支持' : 'Dedicated support', included: true },
      { text: isZh ? 'Kit 市场访问' : 'Kit marketplace access', included: true },
      { text: isZh ? '高级分析面板' : 'Advanced analytics', included: true },
      { text: isZh ? '付费推广 (CPC/置顶)' : 'Paid promotion (CPC/featured)', included: true },
      { text: isZh ? 'SLA 保障' : 'SLA guarantee', included: true },
    ],
    cta: isZh ? '联系我们' : 'Contact Us',
    ctaHref: 'mailto:hello@mcpkit.run',
  },
];
---

<BaseLayout title={isZh ? '定价 — MCPKIT' : 'Pricing — MCPKIT'}>
  <Header />

  <main class="main">
    <div class="page-header">
      <div class="container">
        <h1 class="page-title">{isZh ? '简单透明定价' : 'Simple, Transparent Pricing'}</h1>
        <p class="page-desc">
          {isZh ? '选择适合你的计划，开始使用 AI Agent 工具目录。' : 'Choose the plan that fits you and start using the AI Agent tools directory.'}
        </p>
      </div>
    </div>

    <div class="container">
      <div class="pricing-grid">
        {plans.map(plan => (
          <div class:list={['plan-card', { recommended: plan.recommended }]}>
            {plan.recommended && (
              <div class="recommended-badge">⭐ {isZh ? '推荐' : 'Recommended'}</div>
            )}
            <div class="plan-header">
              <h2 class="plan-name">{plan.name}</h2>
              <p class="plan-description">{plan.description}</p>
            </div>
            <div class="plan-price">
              <span class="price-amount">{plan.price}</span>
              <span class="price-period">{plan.period}</span>
            </div>
            <ul class="plan-features">
              {plan.features.map(feature => (
                <li class:list={['feature-item', { excluded: !feature.included }]}>
                  {feature.included ? (
                    <svg class="check-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  ) : (
                    <svg class="x-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  )}
                  <span>{feature.text}</span>
                </li>
              ))}
            </ul>
            <a href={plan.ctaHref} class:list={['plan-cta', { 'cta-primary': plan.recommended, 'cta-ghost': !plan.recommended }]}>
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main { min-height: calc(100vh - 60px); padding-bottom: 80px; }
  .page-header { text-align: center; padding: 60px 0 48px; border-bottom: 1px solid var(--border-color); }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .page-title { font-size: 36px; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; }
  .page-desc { font-size: 18px; color: var(--text-secondary); }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 48px 0;
  }
  @media (max-width: 768px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }
  .plan-card {
    position: relative;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .plan-card.recommended {
    border-color: var(--accent);
    box-shadow: 0 0 40px var(--accent-muted, rgba(139, 92, 246, 0.15));
  }
  .recommended-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: white;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 100px;
    white-space: nowrap;
  }
  .plan-header { display: flex; flex-direction: column; gap: 8px; }
  .plan-name { font-size: 22px; font-weight: 700; color: var(--text-primary); }
  .plan-description { font-size: 14px; color: var(--text-secondary); }
  .plan-price { display: flex; align-items: baseline; gap: 4px; }
  .price-amount { font-size: 40px; font-weight: 700; color: var(--text-primary); }
  .price-period { font-size: 14px; color: var(--text-tertiary); }
  .plan-features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; flex: 1; }
  .feature-item { display: flex; align-items: center; gap: 10px; font-size: 14px; color: var(--text-primary); }
  .feature-item.excluded { color: var(--text-tertiary); }
  .check-icon { color: var(--success, #22c55e); flex-shrink: 0; }
  .x-icon { color: var(--text-tertiary); flex-shrink: 0; }
  .plan-cta {
    display: block;
    text-align: center;
    padding: 12px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .plan-cta.cta-primary {
    background: var(--accent);
    color: white;
  }
  .plan-cta.cta-primary:hover { background: var(--accent-hover); }
  .plan-cta.cta-ghost {
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--border-color);
  }
  .plan-cta.cta-ghost:hover { border-color: var(--accent); color: var(--accent); }
</style>
