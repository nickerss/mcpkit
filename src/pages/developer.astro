---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';

const tabs = [
  { id: 'submit', label: isZh ? '提交配方' : 'Submit Recipe', href: '#submit' },
  { id: 'claim', label: isZh ? '认领工具' : 'Claim Tool', href: '#claim' },
  { id: 'my-tools', label: isZh ? '我的工具' : 'My Tools', href: '#my-tools' },
];
---

<BaseLayout title={isZh ? '开发者控制台 — MCPKIT' : 'Developer Console — MCPKIT'}>
  <Header />

  <main class="main">
    <div class="page-header">
      <div class="container">
        <h1 class="page-title">{isZh ? '开发者控制台' : 'Developer Console'}</h1>
        <p class="page-desc">
          {isZh ? '提交 Kit 配方、认领工具、管理你的工具列表。' : 'Submit Kit recipes, claim tools, and manage your tool listings.'}
        </p>
      </div>
    </div>

    <div class="container">
      <!-- Tab Navigation -->
      <div class="tab-nav">
        {tabs.map(tab => (
          <a href={tab.href} class="tab-btn">
            {tab.label}
          </a>
        ))}
      </div>

      <!-- Submit Kit Recipe Form -->
      <section id="submit" class="tab-panel">
        <div class="panel-card">
          <h2 class="panel-title">{isZh ? '提交 Kit 配方' : 'Submit Kit Recipe'}</h2>
          <p class="panel-desc">
            {isZh ? '创建一个 Kit 配方，将多个 MCP 工具组合成可复用的场景化解决方案。' : 'Create a Kit recipe that combines multiple MCP tools into a reusable, scenario-based solution.'}
          </p>
          <form class="dev-form" id="submit-kit-form">
            <div class="form-group">
              <label for="kit-name">{isZh ? 'Kit 名称' : 'Kit Name'}</label>
              <input type="text" id="kit-name" name="name" placeholder={isZh ? '例如：SaaS 快速启动套件' : 'e.g. SaaS Fast Start Kit'} required />
            </div>
            <div class="form-group">
              <label for="kit-description">{isZh ? '描述' : 'Description'}</label>
              <textarea id="kit-description" name="description" rows="3" placeholder={isZh ? '简短描述 Kit 的用途和使用场景' : 'Briefly describe what this Kit does and use cases'} required></textarea>
            </div>
            <div class="form-group">
              <label for="kit-category">{isZh ? '分类' : 'Category'}</label>
              <select id="kit-category" name="category">
                <option value="">{isZh ? '选择分类' : 'Select category'}</option>
                <option value="saas">{isZh ? 'SaaS 开发' : 'SaaS Development'}</option>
                <option value="ai-coding">{isZh ? 'AI 编码' : 'AI Coding'}</option>
                <option value="devops">{isZh ? 'DevOps 监控' : 'DevOps & Monitoring'}</option>
                <option value="research">{isZh ? '研究分析' : 'Research & Analysis'}</option>
                <option value="browser">{isZh ? '浏览器自动化' : 'Browser Automation'}</option>
              </select>
            </div>
            <div class="form-group">
              <label for="kit-tools">{isZh ? '包含的工具 (逗号分隔)' : 'Tools Included (comma separated)'}</label>
              <input type="text" id="kit-tools" name="tools" placeholder={isZh ? 'github-mcp, supabase-mcp, claude-code' : 'github-mcp, supabase-mcp, claude-code'} />
            </div>
            <div class="form-group">
              <label for="kit-scenarios">{isZh ? '适用场景 (逗号分隔)' : 'Scenarios (comma separated)'}</label>
              <input type="text" id="kit-scenarios" name="scenarios" placeholder={isZh ? '独立开发, 快速验证, SaaS上线' : 'indie dev, rapid prototyping, SaaS launch'} />
            </div>
            <div class="form-actions">
              <button type="button" class="btn-ghost">{isZh ? '取消' : 'Cancel'}</button>
              <button type="submit" class="btn-primary">{isZh ? '提交审核' : 'Submit for Review'}</button>
            </div>
          </form>
        </div>
      </section>

      <!-- Claim Tool Form -->
      <section id="claim" class="tab-panel">
        <div class="panel-card">
          <h2 class="panel-title">{isZh ? '认领工具' : 'Claim a Tool'}</h2>
          <p class="panel-desc">
            {isZh ? '如果你拥有或维护某个 MCP 工具，可以申请认领以便更新其信息。' : 'If you own or maintain an MCP tool, you can claim it to update its information.'}
          </p>
          <form class="dev-form" id="claim-tool-form">
            <div class="form-group">
              <label for="claim-tool-id">{isZh ? '工具 ID 或 Slug' : 'Tool ID or Slug'}</label>
              <div class="input-with-btn">
                <input type="text" id="claim-tool-id" name="tool_id" placeholder={isZh ? '输入工具 ID' : 'Enter tool ID'} required />
                <button type="button" class="btn-secondary">{isZh ? '查询' : 'Look Up'}</button>
              </div>
            </div>
            <div class="tool-info-placeholder">
              <p class="placeholder-hint">{isZh ? '输入工具 ID 后，这里会显示工具信息' : 'Tool info will appear here after entering tool ID'}</p>
            </div>
            <div class="form-group">
              <label for="claim-github">{isZh ? 'GitHub 仓库 URL' : 'GitHub Repository URL'}</label>
              <input type="url" id="claim-github" name="github_url" placeholder="https://github.com/owner/repo" />
            </div>
            <div class="form-actions">
              <button type="button" class="btn-ghost">{isZh ? '取消' : 'Cancel'}</button>
              <button type="submit" class="btn-primary">{isZh ? '申请认领' : 'Request Claim'}</button>
            </div>
          </form>
        </div>
      </section>

      <!-- My Tools -->
      <section id="my-tools" class="tab-panel">
        <div class="panel-card">
          <h2 class="panel-title">{isZh ? '我的工具' : 'My Tools'}</h2>
          <p class="panel-desc">
            {isZh ? '查看和管理你已经提交或认领的工具。' : 'View and manage tools you have submitted or claimed.'}
          </p>
          <div class="my-tools-list">
            <div class="empty-state">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              <p>{isZh ? '暂无工具' : 'No tools yet'}</p>
              <p class="empty-hint">{isZh ? '提交或认领第一个工具开始' : 'Submit or claim your first tool to get started'}</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const target = btn.getAttribute('href')?.slice(1);
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (target) {
        const panel = document.getElementById(target);
        if (panel) panel.classList.add('active');
      }
      document.querySelectorAll('.tab-panel')[0]?.classList.add('active');
      document.querySelectorAll('.tab-btn')[0]?.classList.add('active');
    });
  });
  // Init first tab
  document.querySelectorAll('.tab-panel')[0]?.classList.add('active');
  document.querySelectorAll('.tab-btn')[0]?.classList.add('active');
</script>

<style>
  .main { min-height: calc(100vh - 60px); padding-bottom: 80px; }
  .page-header { border-bottom: 1px solid var(--border-color); padding: 40px 0 32px; }
  .container { max-width: 720px; margin: 0 auto; padding: 0 24px; }
  .page-title { font-size: 28px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
  .page-desc { color: var(--text-secondary); font-size: 16px; }
  .tab-nav {
    display: flex;
    gap: 4px;
    padding: 32px 0 0;
    border-bottom: 1px solid var(--border-color);
    overflow-x: auto;
  }
  .tab-btn {
    padding: 8px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    border-radius: 8px 8px 0 0;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 150ms ease;
    white-space: nowrap;
  }
  .tab-btn:hover { color: var(--text-primary); }
  .tab-btn.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .tab-panel { display: none; padding-top: 32px; }
  .tab-panel.active { display: block; }
  .panel-card { background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 16px; padding: 32px; }
  .panel-title { font-size: 20px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; }
  .panel-desc { color: var(--text-secondary); font-size: 14px; margin-bottom: 28px; }
  .dev-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 8px; }
  .form-group label { font-size: 14px; font-weight: 600; color: var(--text-primary); }
  .form-group input, .form-group textarea, .form-group select {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-default, #3f3f46);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 14px;
    color: var(--text-primary);
    font-family: inherit;
    transition: border-color 150ms ease;
    outline: none;
  }
  .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
    border-color: var(--accent);
  }
  .form-group input::placeholder, .form-group textarea::placeholder {
    color: var(--text-tertiary);
  }
  .input-with-btn { display: flex; gap: 8px; }
  .input-with-btn input { flex: 1; }
  .tool-info-placeholder {
    background: var(--bg-tertiary);
    border: 1px dashed var(--border-default, #3f3f46);
    border-radius: 8px;
    padding: 24px;
    text-align: center;
  }
  .placeholder-hint { color: var(--text-tertiary); font-size: 14px; }
  .form-actions { display: flex; gap: 12px; justify-content: flex-end; padding-top: 8px; }
  .btn-primary {
    padding: 10px 24px;
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 150ms ease;
  }
  .btn-primary:hover { background: var(--accent-hover); }
  .btn-secondary {
    padding: 10px 16px;
    background: var(--bg-secondary);
    color: var(--text-primary);
    border: 1px solid var(--border-default, #3f3f46);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }
  .btn-ghost {
    padding: 10px 24px;
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
  }
  .my-tools-list { padding-top: 8px; }
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 48px 24px;
    color: var(--text-tertiary);
  }
  .empty-hint { font-size: 13px; color: var(--text-tertiary); }
</style>
