---
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content">
    <h1 class="hero-title">
      {isZh ? '独立开发者的' : 'AI Agent Tools for'}<br/>
      <span class="gradient-text">
        {isZh ? 'AI Agent 工具箱' : 'Independent Developers'}
      </span>
    </h1>
    <p class="hero-desc">
      {isZh
        ? '精选 MCP Servers、AI 编码工具、工作流组件，帮你快速找到「这个场景用什么工具」'
        : 'Curated MCP Servers, AI coding tools, and workflow components — find the right tool for your use case'}
    </p>
    <form class="search-form" action={`/search/?lang=${locale}`} method="get">
      <div class="search-wrap">
        <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          type="text"
          name="q"
          class="search-input"
          placeholder={isZh ? '搜索 MCP Servers、AI 工具...' : 'Search tools...'}
          autocomplete="off"
        />
      </div>
    </form>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 80px 24px 64px;
    text-align: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(99, 102, 241, 0.15), transparent);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--text-primary);
  }
  .gradient-text {
    background: linear-gradient(135deg, var(--accent) 0%, #8b5cf6 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-desc {
    font-size: 18px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 40px;
  }
  .search-form { max-width: 560px; margin: 0 auto; }
  .search-wrap { position: relative; display: flex; align-items: center; }
  .search-icon {
    position: absolute;
    left: 16px;
    color: var(--text-muted);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 16px 16px 16px 48px;
    font-size: 16px;
    color: var(--text-primary);
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    outline: none;
    transition: border-color 200ms ease;
  }
  .search-input::placeholder { color: var(--text-muted); }
  .search-input:focus { border-color: var(--accent); }
</style>
