---
import { getLocaleFromUrl } from '../i18n/index';

interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  price: string;
  website: string;
  logo?: string;
  slug: string;
  featured?: boolean;
}

const { title, description, category, tags, price, website, logo, slug, featured = false } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';
---

<article class:list={["tool-card card-hover", { featured }]}>
  <div class="card-top">
    <div class="logo-wrap">
      {logo ? (
        <img src={logo} alt={title} class="logo" loading="lazy" />
      ) : (
        <div class="logo-placeholder">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
      )}
    </div>
    <div class="top-info">
      <h3 class="card-title">{title}</h3>
      <span class:list={["price-badge", price === 'free' ? 'free' : price === 'paid' ? 'paid' : 'muted']}>
        {price === 'free' ? (isZh ? '免费' : 'Free') : price === 'paid' ? (isZh ? '付费' : 'Paid') : (isZh ? 'Freemium' : 'Freemium')}
      </span>
    </div>
  </div>

  <p class="card-desc">{description}</p>

  <div class="tags">
    {tags.slice(0, 3).map(tag => (
      <span class="tag">{tag}</span>
    ))}
  </div>

  <div class="card-footer">
    <a href={`/tools/${slug}/?lang=${locale}`} class="card-link">
      {isZh ? '查看详情 →' : 'View details →'}
    </a>
    {website && (
      <a href={website} target="_blank" rel="noopener" class="website-link">
        {isZh ? '官网 →' : 'Official site →'}
      </a>
    )}
  </div>
</article>

<style>
  .tool-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tool-card.featured { border-color: rgba(99, 102, 241, 0.4); }
  .card-top { display: flex; align-items: flex-start; gap: 12px; }
  .logo-wrap {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo { width: 100%; height: 100%; object-fit: contain; }
  .logo-placeholder { color: var(--text-muted); }
  .top-info { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .card-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .price-badge {
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 6px;
    width: fit-content;
  }
  .price-badge.free { background: rgba(34, 197, 94, 0.1); color: var(--free); }
  .price-badge.paid { background: rgba(245, 158, 11, 0.1); color: var(--paid); }
  .price-badge.muted { background: var(--bg-tertiary); color: var(--text-secondary); }
  .card-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag { font-size: 12px; padding: 2px 8px; border-radius: 6px; background: var(--tag-bg); color: var(--text-secondary); }
  .card-footer { margin-top: auto; display: flex; gap: 12px; }
  .card-link { font-size: 14px; color: var(--accent); text-decoration: none; transition: color 150ms ease; }
  .card-link:hover { color: var(--accent-hover); }
  .website-link { font-size: 14px; color: var(--text-muted); text-decoration: none; transition: color 150ms ease; }
  .website-link:hover { color: var(--text-secondary); }
</style>
