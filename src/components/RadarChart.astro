---
interface Props {
  scores?: {
    community: number;
    security: number;
    rating: number;
    certified: number;
    overall: number;
  };
  toolSlug?: string;
}

const { scores, toolSlug } = Astro.props;
const defaultScores = {
  community: 50,
  security: 75,
  rating: 60,
  certified: 50,
  overall: 50
};
const data = scores || defaultScores;
---

<div class="radar-container" id="radar-container">
  <div class="radar-chart" id="radar-chart"></div>
  <div class="score-legend">
    <div class="legend-item">
      <span class="legend-dot" style="background: #6366f1"></span>
      <span class="legend-label">Community</span>
      <span class="legend-value">{data.community}</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot" style="background: #22c55e"></span>
      <span class="legend-label">Security</span>
      <span class="legend-value">{data.security}</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot" style="background: #f59e0b"></span>
      <span class="legend-label">Rating</span>
      <span class="legend-value">{data.rating}</span>
    </div>
    <div class="legend-item">
      <span class="legend-dot" style="background: #8b5cf6"></span>
      <span class="legend-label">Certified</span>
      <span class="legend-value">{data.certified}</span>
    </div>
    <div class="legend-item overall">
      <span class="legend-dot" style="background: #ef4444"></span>
      <span class="legend-label">Overall</span>
      <span class="legend-value">{data.overall}</span>
    </div>
  </div>
</div>

<script define:vars={{ data, toolSlug }}>
  function createRadarChart() {
    const container = document.getElementById('radar-chart');
    if (!container) return;

    const size = 200;
    const center = size / 2;
    const radius = 70;
    const labels = ['Community', 'Security', 'Rating', 'Certified', 'Overall'];
    const values = [data.community, data.security, data.rating, data.certified, data.overall];
    const colors = ['#6366f1', '#22c55e', '#f59e0b', '#8b5cf6', '#ef4444'];

    const angleStep = (2 * Math.PI) / labels.length;
    const startAngle = -Math.PI / 2;

    // Create SVG
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('width', String(size));
    svg.setAttribute('height', String(size));
    svg.setAttribute('viewBox', `0 0 ${size} ${size}`);

    // Draw grid circles
    [25, 50, 75, 100].forEach(level => {
      const r = (level / 100) * radius;
      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', String(center));
      circle.setAttribute('cy', String(center));
      circle.setAttribute('r', String(r));
      circle.setAttribute('fill', 'none');
      circle.setAttribute('stroke', '#3f3f46');
      circle.setAttribute('stroke-width', '1');
      svg.appendChild(circle);
    });

    // Draw axis lines and labels
    labels.forEach((label, i) => {
      const angle = startAngle + i * angleStep;
      const x2 = center + radius * Math.cos(angle);
      const y2 = center + radius * Math.sin(angle);

      const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
      line.setAttribute('x1', String(center));
      line.setAttribute('y1', String(center));
      line.setAttribute('x2', String(x2));
      line.setAttribute('y2', String(y2));
      line.setAttribute('stroke', '#3f3f46');
      line.setAttribute('stroke-width', '1');
      svg.appendChild(line);

      // Label
      const labelX = center + (radius + 20) * Math.cos(angle);
      const labelY = center + (radius + 20) * Math.sin(angle);
      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
      text.setAttribute('x', String(labelX));
      text.setAttribute('y', String(labelY));
      text.setAttribute('text-anchor', 'middle');
      text.setAttribute('dominant-baseline', 'middle');
      text.setAttribute('fill', '#9ca3af');
      text.setAttribute('font-size', '10');
      text.textContent = label;
      svg.appendChild(text);
    });

    // Draw data polygon
    const points = values.map((val, i) => {
      const angle = startAngle + i * angleStep;
      const r = (val / 100) * radius;
      return `${center + r * Math.cos(angle)},${center + r * Math.sin(angle)}`;
    }).join(' ');

    const polygon = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
    polygon.setAttribute('points', points);
    polygon.setAttribute('fill', 'rgba(99, 102, 241, 0.3)');
    polygon.setAttribute('stroke', '#6366f1');
    polygon.setAttribute('stroke-width', '2');
    svg.appendChild(polygon);

    // Draw data points
    values.forEach((val, i) => {
      const angle = startAngle + i * angleStep;
      const r = (val / 100) * radius;
      const x = center + r * Math.cos(angle);
      const y = center + r * Math.sin(angle);

      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
      circle.setAttribute('cx', String(x));
      circle.setAttribute('cy', String(y));
      circle.setAttribute('r', '4');
      circle.setAttribute('fill', colors[i]);
      svg.appendChild(circle);
    });

    container.innerHTML = '';
    container.appendChild(svg);
  }

  // Fetch live quality score if toolSlug provided
  async function fetchQualityScore() {
    if (!toolSlug) {
      createRadarChart();
      return;
    }

    try {
      const res = await fetch(`/api/tools/${toolSlug}`);
      if (res.ok) {
        const tool = await res.json();
        if (tool.quality_score !== undefined) {
          // Update legend values with live data
          document.querySelectorAll('.legend-value').forEach((el, i) => {
            const keys = ['community', 'security', 'rating', 'certified', 'overall'];
            if (tool.quality_score && tool.quality_score[keys[i]]) {
              el.textContent = String(tool.quality_score[keys[i]]);
            }
          });
        }
      }
    } catch (e) {
      console.log('Could not fetch quality score');
    }
    createRadarChart();
  }

  fetchQualityScore();
</script>

<style>
  .radar-container {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 24px;
  }
  .radar-chart {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }
  .score-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
  }
  .legend-item.overall {
    font-weight: 600;
  }
  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .legend-label {
    color: var(--text-secondary);
  }
  .legend-value {
    color: var(--text-primary);
    font-weight: 600;
  }
</style>
