---
import { getLocaleFromUrl } from '../i18n/index';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';

const locale = getLocaleFromUrl(Astro.url);
const langParam = locale === 'zh' ? '?lang=zh' : '';
---

<header class="header">
  <div class="header-inner">
    <a href={`/${langParam}`} class="logo">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="logo-g-h" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#6366f1"/>
            <stop offset="100%" stop-color="#8b5cf6"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="6" fill="url(#logo-g-h)"/>
        <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-size="14" font-weight="bold" fill="white">M</text>
      </svg>
      <span>MCPKIT</span>
    </a>

    <nav class="nav">
      <a href="/ai-tools/" class="nav-link"><span class="en-hide">Explore Tools</span><span class="zh-show">探索工具</span></a>
      <a href="/kits/" class="nav-link"><span class="en-hide">Kit Zone</span><span class="zh-show">Kit专区</span></a>
      <a href="/developer/" class="nav-link"><span class="en-hide">Developers</span><span class="zh-show">开发者</span></a>
      <a href="/pricing/" class="nav-link"><span class="en-hide">Pricing</span><span class="zh-show">定价</span></a>
    </nav>

    <div class="right-area desktop-only">
      <ThemeSwitcher />
      <LanguageSwitcher />
      <span id="user-info" style="display:none">
        <a href="/dashboard/" id="user-name" class="user-link"></a>
        <a href="https://api.mcpkit.run/api/auth/logout" class="btn-logout"><span class="en-hide">Logout</span><span class="zh-show">退出</span></a>
      </span>
      <a id="login-btn" href="https://api.mcpkit.run/api/auth/github" class="btn-login"><span class="en-hide">Login</span><span class="zh-show">登录</span></a>
      <a href="/submit/" class="cta-btn"><span class="en-hide">Submit Tool</span><span class="zh-show">提交工具</span></a>
    </div>

    <!-- Mobile Hamburger -->
    <button class="hamburger" id="hamburger-btn" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Drawer Overlay -->
<div class="drawer-overlay" id="drawer-overlay"></div>

<!-- Mobile Drawer -->
<aside class="drawer" id="mobile-drawer">
  <div class="drawer-header">
    <span class="drawer-logo">MCPKIT</span>
    <button class="drawer-close" id="drawer-close" aria-label="Close menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <nav class="drawer-nav">
    <a href="/ai-tools/" class="drawer-link"><span class="en-hide">Explore Tools</span><span class="zh-show">探索工具</span></a>
    <a href="/kits/" class="drawer-link"><span class="en-hide">Kit Zone</span><span class="zh-show">Kit专区</span></a>
    <a href="/developer/" class="drawer-link"><span class="en-hide">Developers</span><span class="zh-show">开发者</span></a>
    <a href="/pricing/" class="drawer-link"><span class="en-hide">Pricing</span><span class="zh-show">定价</span></a>
  </nav>
  <div class="drawer-footer">
    <div class="drawer-tools">
      <ThemeSwitcher />
      <LanguageSwitcher />
    </div>
    <a id="login-btn-mobile" href="https://api.mcpkit.run/api/auth/github" class="drawer-btn drawer-btn-secondary"><span class="en-hide">Login</span><span class="zh-show">登录</span></a>
    <a href="/submit/" class="drawer-btn drawer-btn-primary"><span class="en-hide">Submit Tool</span><span class="zh-show">提交工具</span></a>
  </div>
</aside>

<script>
  const hamburger = document.getElementById('hamburger-btn');
  const drawer = document.getElementById('mobile-drawer');
  const overlay = document.getElementById('drawer-overlay');
  const closeBtn = document.getElementById('drawer-close');

  function openDrawer() {
    drawer?.classList.add('open');
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    drawer?.classList.remove('open');
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  overlay?.addEventListener('click', closeDrawer);

  // Close on link click
  drawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeDrawer);
  });
</script>

<script>
  function updateHeaderLang(lang: string) {
    const isZh = lang === 'zh';
    const labels: Record<string, Record<string, string>> = {
      en: { login: 'Login', logout: 'Logout', submit: 'Submit Tool' },
      zh: { login: '登录', logout: '退出', submit: '提交工具' }
    };
    const texts = labels[lang] || labels.en;
    
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && texts[key]) {
        el.textContent = texts[key];
      }
    });
    
    const loginBtn = document.getElementById('login-btn');
    const submitBtn = document.querySelector('.cta-btn');
    if (submitBtn) submitBtn.setAttribute('href', isZh ? '/submit/?lang=zh' : '/submit/');
  }
  
  function getLang() {
    const urlLang = new URLSearchParams(window.location.search).get('lang');
    const storedLang = localStorage.getItem('mcpkit-lang');
    return urlLang || storedLang || 'en';
  }
  
  updateHeaderLang(getLang());

  async function checkAuth() {
    try {
      const res = await fetch('https://api.mcpkit.run/api/users/me', { credentials: 'include' });
      if (res.ok) {
        const user = await res.json();
        const loginBtn = document.getElementById('login-btn');
        const loginBtnMobile = document.getElementById('login-btn-mobile');
        const userInfo = document.getElementById('user-info');
        if (loginBtn) loginBtn.style.display = 'none';
        if (loginBtnMobile) loginBtnMobile.style.display = 'none';
        if (userInfo) userInfo.style.display = 'flex';
        const userName = document.getElementById('user-name');
        if (userName) userName.textContent = user.username || user.name || 'User';
      }
    } catch (e) {}
  }
  checkAuth();
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-subtle);
  }
  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo svg { flex-shrink: 0; }
  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    overflow-x: auto;
  }
  .nav-link {
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    border-radius: 8px;
    text-decoration: none;
    transition: color 150ms ease, background-color 150ms ease;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .right-area {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .desktop-only {
    display: flex;
  }
  .btn-login {
    padding: 7px 14px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    border-radius: 8px;
    text-decoration: none;
    transition: color 150ms ease, background-color 150ms ease;
    border: 1px solid transparent;
  }
  .btn-login:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .cta-btn {
    padding: 7px 14px;
    font-size: 14px;
    font-weight: 600;
    color: white;
    background: var(--accent);
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 150ms ease;
    white-space: nowrap;
  }
  .cta-btn:hover { background: var(--accent-hover); }

  #user-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .user-link {
    color: var(--text-primary);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .user-link:hover { color: var(--accent); }
  .btn-logout {
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .btn-logout:hover {
    color: var(--danger);
    border-color: var(--danger);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    padding: 8px;
    background: transparent;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    border-radius: 8px;
    transition: background 150ms ease;
  }
  .hamburger:hover {
    background: var(--bg-tertiary);
  }

  /* Mobile Drawer */
  .drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 200;
    opacity: 0;
    transition: opacity 200ms ease;
  }
  .drawer-overlay.open {
    opacity: 1;
  }
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 280px;
    background: var(--bg-secondary);
    border-left: 1px solid var(--border-subtle);
    z-index: 201;
    transform: translateX(100%);
    transition: transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }
  .drawer.open {
    transform: translateX(0);
  }
  .drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-subtle);
  }
  .drawer-logo {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .drawer-close {
    padding: 8px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    border-radius: 8px;
    transition: background 150ms ease;
  }
  .drawer-close:hover {
    background: var(--bg-tertiary);
  }
  .drawer-nav {
    display: flex;
    flex-direction: column;
    padding: 16px 12px;
    gap: 4px;
    flex: 1;
  }
  .drawer-link {
    padding: 12px 16px;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: 8px;
    transition: all 150ms ease;
  }
  .drawer-link:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .drawer-footer {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 20px;
    border-top: 1px solid var(--border-subtle);
  }
  .drawer-tools {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .drawer-btn {
    display: block;
    text-align: center;
    padding: 12px 16px;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .drawer-btn-secondary {
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    background: transparent;
  }
  .drawer-btn-secondary:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }
  .drawer-btn-primary {
    color: white;
    background: var(--accent);
  }
  .drawer-btn-primary:hover {
    background: var(--accent-hover);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .nav { display: none; }
    .desktop-only { display: none; }
    .hamburger { display: flex; }
    .drawer-overlay { display: block; pointer-events: none; }
    .drawer-overlay.open { pointer-events: auto; }
  }
</style>
