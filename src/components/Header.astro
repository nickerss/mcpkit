---
import { getLocaleFromUrl } from '../i18n/index';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeSwitcher from './ThemeSwitcher.astro';

const locale = getLocaleFromUrl(Astro.url);
const langParam = locale === 'zh' ? '?lang=zh' : '';

const navLinks = [
  { id: 'explore', href: '/ai-tools/', label: 'Explore Tools', zhLabel: '探索工具' },
  { id: 'kits', href: '/kits/', label: 'Kit Zone', zhLabel: 'Kit专区' },
  { id: 'developers', href: '/developer/', label: 'Developers', zhLabel: '开发者' },
  { id: 'pricing', href: '/pricing/', label: 'Pricing', zhLabel: '定价' },
];
---

<header class="header">
  <div class="header-inner">
    <a href={`/${langParam}`} class="logo">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="logo-g-h" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#6366f1"/>
            <stop offset="100%" stop-color="#8b5cf6"/>
          </linearGradient>
        </defs>
        <rect width="32" height="32" rx="6" fill="url(#logo-g-h)"/>
        <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-size="14" font-weight="bold" fill="white">M</text>
      </svg>
      <span>MCPKIT</span>
    </a>

    <nav class="nav">
      {navLinks.map(link => (
        <a href={link.href} class="nav-link" data-i18n={`nav.${link.id}`}>{locale === 'zh' ? link.zhLabel : link.label}</a>
      ))}
    </nav>

    <div class="right-area">
      <ThemeSwitcher />
      <LanguageSwitcher />
      <span id="user-info" style="display:none">
        <a href="/dashboard/" id="user-name" class="user-link"></a>
        <a href="https://api.mcpkit.run/api/auth/logout" class="btn-logout" data-i18n="nav.logout">Logout</a>
      </span>
      <a id="login-btn" href="https://api.mcpkit.run/api/auth/github" class="btn-login" data-i18n="nav.login">Login</a>
      <a href={`/submit/`} class="cta-btn" data-i18n="nav.submit">Submit Tool</a>
    </div>
  </div>
</header>

<script>
  function updateHeaderLang(lang: string) {
    const isZh = lang === 'zh';
    const labels: Record<string, Record<string, string>> = {
      en: { login: 'Login', logout: 'Logout', submit: 'Submit Tool' },
      zh: { login: '登录', logout: '退出', submit: '提交工具' }
    };
    const texts = labels[lang] || labels.en;
    
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && texts[key]) {
        el.textContent = texts[key];
      }
    });
    
    const loginBtn = document.getElementById('login-btn');
    const submitBtn = document.querySelector('.cta-btn');
    if (submitBtn) submitBtn.setAttribute('href', isZh ? '/submit/?lang=zh' : '/submit/');
  }
  
  function getLang() {
    const urlLang = new URLSearchParams(window.location.search).get('lang');
    const storedLang = localStorage.getItem('mcpkit-lang');
    return urlLang || storedLang || 'en';
  }
  
  updateHeaderLang(getLang());

  async function checkAuth() {
    try {
      const res = await fetch('https://api.mcpkit.run/api/users/me', { credentials: 'include' });
      if (res.ok) {
        const user = await res.json();
        document.getElementById('login-btn').style.display = 'none';
        document.getElementById('user-info').style.display = 'flex';
        document.getElementById('user-name').textContent = user.username || user.name || 'User';
      }
    } catch (e) {}
  }
  checkAuth();
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 64px;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-subtle);
  }
  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo svg { flex-shrink: 0; }
  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
    overflow-x: auto;
  }
  .nav-link {
    padding: 6px 12px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    border-radius: 8px;
    text-decoration: none;
    transition: color 150ms ease, background-color 150ms ease;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .right-area {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .btn-login {
    padding: 7px 14px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary);
    border-radius: 8px;
    text-decoration: none;
    transition: color 150ms ease, background-color 150ms ease;
    border: 1px solid transparent;
  }
  .btn-login:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .cta-btn {
    padding: 7px 14px;
    font-size: 14px;
    font-weight: 600;
    color: white;
    background: var(--accent);
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 150ms ease;
    white-space: nowrap;
  }
  .cta-btn:hover { background: var(--accent-hover); }

  #user-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .user-link {
    color: var(--text-primary);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .user-link:hover { color: var(--accent); }
  .btn-logout {
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    background: transparent;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    text-decoration: none;
    transition: all 150ms ease;
  }
  .btn-logout:hover {
    color: var(--danger);
    border-color: var(--danger);
  }
</style>
