---
interface Props {
  price: string;
}

const { price } = Astro.props;
const label = price === 'free' ? '免费' : price === 'paid' ? '付费' : price;
const color = price === 'free' ? 'free' : price === 'paid' ? 'paid' : 'muted';
---

<span class:list={["price-badge", color]}>{label}</span>

<style>
  .price-badge {
    display: inline-block;
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 6px;
  }
  .free {
    background: rgba(34, 197, 94, 0.1);
    color: var(--free);
  }
  .paid {
    background: rgba(245, 158, 11, 0.1);
    color: var(--paid);
  }
  .muted {
    background: var(--bg-tertiary);
    color: var(--text-secondary);
  }
</style>
