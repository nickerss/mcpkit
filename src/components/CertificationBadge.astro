---
interface Props {
  status: 'certified' | 'recommended' | 'reviewed' | 'pending';
  size?: 'sm' | 'md';
}

const { status, size = 'md' } = Astro.props;

const config = {
  certified: {
    label: '🏅 MCPKIT Certified',
    class: 'cert-certified',
    animate: true,
  },
  recommended: {
    label: '✅ Kit Recommended',
    class: 'cert-recommended',
    animate: false,
  },
  reviewed: {
    label: '✓ Reviewed',
    class: 'cert-reviewed',
    animate: false,
  },
  pending: {
    label: '⏳ Pending',
    class: 'cert-pending',
    animate: false,
  },
};

const cert = config[status] || config.pending;
---

<span class={`cert-badge ${cert.class} cert-${size}`}>
  {cert.label}
</span>

<style>
  .cert-badge {
    display: inline-flex;
    align-items: center;
    font-weight: 600;
    border-radius: 999px;
    white-space: nowrap;
  }
  .cert-md {
    font-size: 12px;
    padding: 4px 12px;
  }
  .cert-sm {
    font-size: 11px;
    padding: 2px 8px;
  }
  .cert-certified {
    background: linear-gradient(135deg, #f59e0b, #fbbf24);
    color: white;
    animation: pulse-glow 2s ease-in-out infinite;
  }
  .cert-certified.cert-animate {
    animation: pulse-glow 2s ease-in-out infinite;
  }
  .cert-recommended {
    background: #22c55e20;
    color: #22c55e;
  }
  .cert-reviewed {
    border: 1px solid var(--border);
    color: var(--text-muted);
    background: transparent;
  }
  .cert-pending {
    color: var(--text-muted);
    background: transparent;
  }
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(245, 158, 11, 0); }
  }
</style>