---
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
const isZh = locale === 'zh';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <div class="brand-row">
        <svg width="22" height="22" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="footer-logo-h" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#6366f1"/>
              <stop offset="100%" stop-color="#8b5cf6"/>
            </linearGradient>
          </defs>
          <rect width="32" height="32" rx="6" fill="url(#footer-logo-h)"/>
          <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle" font-size="14" font-weight="bold" fill="white">M</text>
        </svg>
        <span class="brand-name">MCPKIT</span>
      </div>
      <p class="brand-tagline">
        {isZh
          ? 'AI Agent 时代的一站式 MCP 工具包发现、认证与分发平台'
          : 'One-stop MCP toolkit discovery, verification & distribution platform for the AI Agent era'}
      </p>
    </div>

    <div class="footer-links-grid">
      <div class="link-group">
        <h4 class="link-group-title">{isZh ? '产品' : 'Product'}</h4>
        <a href="/kits/" class="footer-link">{isZh ? 'Kit 专区' : 'Kit Zone'}</a>
        <a href="/ai-tools/" class="footer-link">{isZh ? '探索工具' : 'Explore Tools'}</a>
        <a href="/pricing/" class="footer-link">{isZh ? '定价' : 'Pricing'}</a>
        <a href="/search/" class="footer-link">{isZh ? '搜索' : 'Search'}</a>
      </div>
      <div class="link-group">
        <h4 class="link-group-title">{isZh ? '开发者' : 'Developers'}</h4>
        <a href="/developer/" class="footer-link">{isZh ? '开发者控制台' : 'Developer Console'}</a>
        <a href="/submit/" class="footer-link">{isZh ? '提交工具' : 'Submit Tool'}</a>
        <a href="/dashboard/claim-tool/" class="footer-link">{isZh ? '认领工具' : 'Claim Tool'}</a>
      </div>
      <div class="link-group">
        <h4 class="link-group-title">{isZh ? '关于' : 'About'}</h4>
        <a href="#" class="footer-link">{isZh ? '关于我们' : 'About'}</a>
        <a href="#" class="footer-link">{isZh ? '文档' : 'Docs'}</a>
        <a href="#" class="footer-link">{isZh ? '社区' : 'Community'}</a>
        <a href="#" class="footer-link">{isZh ? '隐私政策' : 'Privacy'}</a>
        <a href="#" class="footer-link">{isZh ? '服务条款' : 'Terms'}</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p class="copyright">
      © {year} mcpkit.run — {isZh ? '保留所有权利' : 'All rights reserved'}
    </p>
    <p class="built-with">
      {isZh ? '为 AI Agent 开发者而生' : 'Built for AI Agent developers'}
    </p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-subtle);
    padding: 48px 24px 24px;
    background: var(--bg-primary);
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    gap: 64px;
    flex-wrap: wrap;
    margin-bottom: 40px;
  }
  .footer-brand {
    flex: 0 0 280px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-name {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .brand-tagline {
    font-size: 13px;
    color: var(--text-tertiary);
    line-height: 1.6;
    max-width: 260px;
  }
  .footer-links-grid {
    display: flex;
    gap: 48px;
    flex: 1;
    flex-wrap: wrap;
  }
  .link-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 100px;
  }
  .link-group-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 4px;
  }
  .footer-link {
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .footer-link:hover { color: var(--text-primary); }

  .footer-bottom {
    max-width: 1280px;
    margin: 0 auto;
    padding-top: 20px;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }
  .copyright {
    font-size: 13px;
    color: var(--text-tertiary);
  }
  .built-with {
    font-size: 13px;
    color: var(--text-tertiary);
  }
</style>
