---
import { getLocaleFromUrl } from '../i18n/index';

const locale = getLocaleFromUrl(Astro.url);
---

<footer class="footer">
  <div class="footer-inner">
    <p class="copyright">
      {locale === 'zh'
        ? `© ${new Date().getFullYear()} MCPKIT — 独立开发者的 AI Agent 工具箱`
        : `© ${new Date().getFullYear()} MCPKIT — AI Agent Tools for Independent Developers`}
    </p>
    <div class="links">
      <a href={`/submit/?lang=${locale}`} class="link">
        {locale === 'zh' ? '提交工具' : 'Submit Tool'}
      </a>
      <a href={`/search/?lang=${locale}`} class="link">
        {locale === 'zh' ? '搜索' : 'Search'}
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-color);
    padding: 32px 24px;
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .copyright {
    font-size: 14px;
    color: var(--text-muted);
  }
  .links {
    display: flex;
    gap: 24px;
  }
  .link {
    font-size: 14px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }
  .link:hover { color: var(--text-secondary); }
</style>
