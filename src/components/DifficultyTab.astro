---
interface Props {
  current?: 'starter' | 'pro' | 'enterprise';
  baseUrl: string;
}

const { current = 'starter', baseUrl } = Astro.props;
const levels = ['starter', 'pro', 'enterprise'] as const;

const labels = {
  starter: 'Starter',
  pro: 'Pro',
  enterprise: 'Enterprise',
};

const desc = {
  starter: 'Basic setup, ready to use',
  pro: 'Advanced configuration',
  enterprise: 'Full-featured, unlimited',
};

const colors = {
  starter: 'var(--free)',
  pro: 'var(--paid)',
  enterprise: '#ef4444',
};
---

<div class="level-cards">
  {levels.map(level => (
    <a
      href={`${baseUrl}?level=${level}`}
      class={`level-card ${current === level ? 'active' : ''}`}
      style={`--card-color: ${colors[level]}`}
      data-level={level}
    >
      <span class="card-label">{labels[level]}</span>
      <span class="card-desc en-hide">{desc[level]}</span>
    </a>
  ))}
</div>

<style>
  .level-cards {
    display: flex;
    gap: 12px;
    margin-bottom: 24px;
  }
  .level-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 16px 12px;
    background: var(--bg-secondary);
    border: 2px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: all 200ms ease;
    cursor: pointer;
  }
  .level-card:hover {
    border-color: var(--card-color);
    transform: translateY(-2px);
  }
  .level-card.active {
    border-color: var(--card-color);
    background: color-mix(in srgb, var(--card-color) 10%, transparent);
  }
  .card-label {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
  }
  .level-card.active .card-label {
    color: var(--card-color);
  }
  .card-desc {
    font-size: 12px;
    color: var(--text-muted);
  }
  .level-card .card-desc.zh-show {
    display: none;
  }
</style>

<script>
  // Sync active state with URL param (for static pages)
  const params = new URLSearchParams(window.location.search);
  const level = params.get('level') || 'starter';
  const cards = document.querySelectorAll('.level-card');
  cards.forEach(card => {
    if (card.getAttribute('data-level') === level) {
      card.classList.add('active');
    } else {
      card.classList.remove('active');
    }
  });
</script>
