---
interface FilterOption {
  id: string;
  label: string;
  count?: number;
}

interface Props {
  title: string;
  options: FilterOption[];
  activeFilter?: string;
}

const { title, options, activeFilter } = Astro.props;
---

<div class="filter-sidebar">
  <h3 class="filter-title">{title}</h3>
  <ul class="filter-list">
    {options.map(opt => (
      <li>
        <button
          class:list={["filter-btn", { active: activeFilter === opt.id }]}
          data-filter={opt.id}
        >
          <span class="filter-label">{opt.label}</span>
          {opt.count !== undefined && (
            <span class="filter-count">{opt.count}</span>
          )}
        </button>
      </li>
    ))}
  </ul>
</div>

<style>
  .filter-sidebar {
    width: 240px;
    flex-shrink: 0;
  }
  .filter-title {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    margin-bottom: 12px;
  }
  .filter-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .filter-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    font-size: 14px;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    transition: color 150ms ease, background-color 150ms ease;
    border-left: 2px solid transparent;
  }
  .filter-btn:hover {
    color: var(--text-primary);
    background: var(--bg-tertiary);
  }
  .filter-btn.active {
    color: var(--accent);
    background: rgba(99, 102, 241, 0.1);
    border-left-color: var(--accent);
  }
  .filter-label {
    flex: 1;
  }
  .filter-count {
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
